# Kamal secrets — DO NOT commit actual values to version control.
# Set these as environment variables or use a password manager integration.
#
# Required for deployment:
#   KAMAL_REGISTRY_USERNAME   — GitHub username for ghcr.io
#   KAMAL_REGISTRY_PASSWORD   — GitHub personal access token (write:packages scope)
#   RAILS_MASTER_KEY          — config/master.key contents
#   DATABASE_URL              — PostgreSQL connection URL for production
#   POSTGRES_PASSWORD         — Password for the Postgres accessory container
#   GOOGLE_CLIENT_ID          — Google OAuth2 client ID
#   GOOGLE_CLIENT_SECRET      — Google OAuth2 client secret
#   SSH_PRIVATE_KEY           — SSH key with access to DROPLET_IP (used in GitHub Actions)

KAMAL_REGISTRY_USERNAME=$KAMAL_REGISTRY_USERNAME
KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD
RAILS_MASTER_KEY=$(cat config/master.key)
DATABASE_URL=$DATABASE_URL
POSTGRES_PASSWORD=$POSTGRES_PASSWORD
GOOGLE_CLIENT_ID=$GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=$GOOGLE_CLIENT_SECRET
