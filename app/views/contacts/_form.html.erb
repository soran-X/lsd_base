<%= form_with model: contact, class: "space-y-0" do |f| %>
  <% if contact.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6 text-sm text-red-700">
      <ul class="list-disc list-inside space-y-0.5">
        <% contact.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
      </ul>
    </div>
  <% end %>

  <%# ── Save (top) ──────────────────────────────────────────────────────── %>
  <div class="flex items-center gap-3 mb-6">
    <%= f.submit class: "inline-flex items-center px-5 py-2.5 bg-indigo-600 text-white text-sm
                          font-medium rounded-lg hover:bg-indigo-700 transition-colors cursor-pointer" %>
    <%= link_to "Cancel", contact.persisted? ? contact_path(contact) : contacts_path,
          class: "inline-flex items-center px-4 py-2 bg-white text-gray-700 text-sm
                  font-medium rounded-lg border border-gray-200 hover:bg-gray-50 transition-colors" %>
  </div>

  <%# ── Primary Info ────────────────────────────────────────────────────── %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 mb-5">
    <div class="bg-gray-50 px-5 py-2.5 border-b border-gray-200 rounded-t-xl">
      <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Primary Info</p>
    </div>
    <div class="p-5 space-y-4">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <%= f.label :last_name, "Last Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :last_name, autofocus: true,
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                        focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
        </div>
        <div>
          <%= f.label :first_name, "First Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :first_name,
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                        focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
        </div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <%= f.label :email, "Email", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.email_field :email,
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                        focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
        </div>
        <div>
          <%= f.label :title, "Position", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :title, placeholder: "e.g. Senior Editor",
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                        focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
        </div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <%= f.label :assistant_name, "Assistant's Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :assistant_name,
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                        focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
        </div>
      </div>
    </div>
  </div>

  <%# ── Contact Info ────────────────────────────────────────────────────── %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden mb-5">
    <div class="bg-gray-50 px-5 py-2.5 border-b border-gray-200">
      <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Contact Info</p>
    </div>
    <div class="p-5">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_1px_1fr] gap-y-6 lg:gap-y-0">

        <%# Column 1 — Address -%>
        <div class="space-y-4 lg:pr-10">
          <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Address</p>
          <div>
            <%= f.label :address_line_1, "Address Line 1", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.text_field :address_line_1,
                  class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                          focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
          </div>
          <div>
            <%= f.label :address_line_2, "Address Line 2", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.text_field :address_line_2,
                  class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                          focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <%= f.label :city, "City", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= f.text_field :city,
                    class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                            focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
            </div>
            <div>
              <%= f.label :state, "State", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= f.text_field :state,
                    class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                            focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <%= f.label :country, "Country", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= f.text_field :country,
                    class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                            focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
            </div>
            <div>
              <%= f.label :zip, "Zip / Postal Code", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= f.text_field :zip,
                    class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                            focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
            </div>
          </div>
        </div>

        <%# Divider -%>
        <div class="hidden lg:block bg-gray-200"></div>

        <%# Column 2 — Phone numbers -%>
        <div class="space-y-4 lg:pl-10 border-t border-gray-100 lg:border-t-0">
          <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Phone Numbers</p>
          <div>
            <%= f.label :phone, "Main Number", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.telephone_field :phone,
                  class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                          focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
          </div>
          <div>
            <%= f.label :direct_number, "Direct Number", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.telephone_field :direct_number,
                  class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                          focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
          </div>
          <div>
            <%= f.label :mobile_number, "Mobile Number", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.telephone_field :mobile_number,
                  class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                          focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
          </div>
          <div>
            <%= f.label :home_number, "Home Number", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.telephone_field :home_number,
                  class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                          focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
          </div>
          <div>
            <%= f.label :fax_number, "Fax Number", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.telephone_field :fax_number,
                  class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                          focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
          </div>
        </div>

      </div>
    </div>
  </div>

  <%# ── Notes ──────────────────────────────────────────────────────────── %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 mb-5">
    <div class="bg-gray-50 px-5 py-2.5 border-b border-gray-200">
      <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Notes</p>
    </div>
    <div class="p-5 space-y-4">
<div data-controller="rich-text"
           data-rich-text-name-value="contact[notes]"
           data-rich-text-value-value="<%= @contact.notes.to_s %>"></div>

      <%# Tracked By — single-select user combobox -%>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Tracked By</label>
        <% tracked_label = contact.tracked_by&.display_name.to_s %>
        <div data-controller="company-combobox"
             data-company-combobox-url-value="<%= search_users_path(format: :json) %>"
             class="relative">
          <div class="flex items-center gap-2">
            <input type="text"
                   data-company-combobox-target="input"
                   value="<%= tracked_label %>"
                   placeholder="Search users…"
                   autocomplete="off"
                   data-action="input->company-combobox#search keydown->company-combobox#onKeydown"
                   class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                          focus:outline-none focus:ring-2 focus:ring-indigo-500">
            <% if contact.tracked_by_id.present? %>
              <button type="button"
                      data-action="click->company-combobox#clear"
                      class="text-gray-400 hover:text-gray-600 transition-colors shrink-0"
                      title="Clear">
                <svg class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-2.72 2.72a.75.75 0 101.06 1.06L10 11.06l2.72 2.72a.75.75 0 101.06-1.06L11.06 10l2.72-2.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z"/>
                </svg>
              </button>
            <% end %>
          </div>
          <%= f.hidden_field :tracked_by_id, data: { "company-combobox-target": "hiddenField" } %>
          <div data-company-combobox-target="dropdown"
               class="hidden absolute z-50 left-0 right-0 mt-1 bg-white rounded-lg border
                      border-gray-200 shadow-lg overflow-hidden max-h-52 overflow-y-auto">
          </div>
        </div>
      </div>
    </div>
  </div>

  <%# ── Companies ───────────────────────────────────────────────────────── %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 mb-5">
    <div class="bg-gray-50 px-5 py-2.5 border-b border-gray-200">
      <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Companies</p>
    </div>
    <div class="p-5">
      <% extra_companies = contact.persisted? ? contact.companies.map { |c| { id: c.id, label: c.name } } : [] %>
      <div data-controller="company-chips"
           data-company-chips-search-url-value="<%= search_companies_path(format: :json) %>"
           data-company-chips-field-name-value="contact[company_ids][]"
           class="space-y-2">
        <div data-company-chips-target="chips" class="flex flex-wrap gap-1.5 min-h-[2rem]">
          <% extra_companies.each do |c| %>
            <div class="inline-flex items-center gap-2 pl-3 pr-2 py-1.5 rounded-full text-sm font-medium
                        bg-sky-50 text-sky-800 border border-sky-200"
                 data-company-id="<%= c[:id] %>" data-company-label="<%= c[:label] %>">
              <span><%= c[:label] %></span>
              <input type="hidden" name="contact[company_ids][]" value="<%= c[:id] %>">
              <button type="button" data-company-id="<%= c[:id] %>"
                      data-action="click->company-chips#removeChip"
                      class="rounded-full p-0.5 hover:bg-sky-200 text-sky-400 hover:text-sky-700 transition-colors">
                <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-2.72 2.72a.75.75 0 101.06 1.06L10 11.06l2.72 2.72a.75.75 0 101.06-1.06L11.06 10l2.72-2.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z"/>
                </svg>
              </button>
            </div>
          <% end %>
        </div>
        <div class="relative">
          <input type="text"
                 data-company-chips-target="input"
                 placeholder="Search and add companies…"
                 autocomplete="off"
                 class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                         focus:outline-none focus:ring-2 focus:ring-indigo-500"
                 data-action="input->company-chips#onInput keydown->company-chips#onKeydown" />
          <div data-company-chips-target="dropdown"
               class="hidden absolute z-50 left-0 right-0 mt-1 bg-white rounded-lg border
                      border-gray-200 shadow-lg overflow-hidden max-h-52 overflow-y-auto">
            <ul data-company-chips-target="list" role="listbox"></ul>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%# ── Save (bottom) ──────────────────────────────────────────────────── %>
  <div class="flex items-center gap-3">
    <%= f.submit class: "inline-flex items-center px-5 py-2.5 bg-indigo-600 text-white text-sm
                          font-medium rounded-lg hover:bg-indigo-700 transition-colors cursor-pointer" %>
    <%= link_to "Cancel", contact.persisted? ? contact_path(contact) : contacts_path,
          class: "inline-flex items-center px-4 py-2 bg-white text-gray-700 text-sm
                  font-medium rounded-lg border border-gray-200 hover:bg-gray-50 transition-colors" %>
  </div>
<% end %>
