<%# ── Header ──────────────────────────────────────────────────────────────── %>
<div class="flex items-center justify-between mb-6 gap-4 flex-wrap">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Contacts</h1>
    <p class="text-sm text-gray-500 mt-0.5"><%= @contacts.size %> <%= "contact".pluralize(@contacts.size) %></p>
  </div>
  <div class="flex items-center gap-3">
    <%= form_with url: contacts_path, method: :get, class: "flex items-center gap-2" do |f| %>
      <%= f.text_field :q, value: @query, placeholder: "Search contacts…",
            class: "block rounded-lg border border-gray-300 px-3 py-2 text-sm w-56
                    focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
      <% if @query.present? %>
        <%= link_to "Clear", contacts_path,
              class: "text-xs text-gray-400 hover:text-gray-600" %>
      <% end %>
    <% end %>
    <%= link_to "New Contact", new_contact_path,
          class: "inline-flex items-center gap-1.5 px-4 py-2 bg-indigo-600 text-white text-sm
                  font-medium rounded-lg hover:bg-indigo-700 transition-colors" %>
  </div>
</div>

<%# ── Table ───────────────────────────────────────────────────────────────── %>
<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
  <% if @contacts.any? %>
    <table class="min-w-full divide-y divide-gray-100 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Name</th>
          <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider hidden sm:table-cell">Title</th>
          <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider hidden md:table-cell">Company</th>
          <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider hidden lg:table-cell">Email</th>
          <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider hidden md:table-cell">Phone</th>
          <th class="px-5 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @contacts.each do |contact| %>
          <tr class="hover:bg-gray-50 group">
            <td class="px-5 py-3 font-medium text-gray-900">
              <%= link_to contact.display_name, contact_path(contact),
                    class: "hover:text-indigo-600 transition-colors" %>
            </td>
            <td class="px-5 py-3 text-gray-500 hidden sm:table-cell">
              <%= contact.title.presence || "—" %>
            </td>
            <td class="px-5 py-3 text-gray-500 hidden md:table-cell">
              <% if contact.companies.any? %>
                <%= contact.companies.map { |c| link_to(c.name, company_path(c), class: "hover:text-indigo-600 transition-colors") }.join(", ").html_safe %>
              <% else %>
                —
              <% end %>
            </td>
            <td class="px-5 py-3 text-gray-500 hidden lg:table-cell">
              <%= contact.email.present? ? mail_to(contact.email, contact.email, class: "hover:text-indigo-600") : "—" %>
            </td>
            <td class="px-5 py-3 text-gray-500 hidden md:table-cell">
              <%= contact.phone.presence || "—" %>
            </td>
            <td class="px-5 py-3 text-right">
              <div class="flex items-center justify-end gap-3 opacity-0 group-hover:opacity-100 transition-opacity">
                <%= link_to "Edit", edit_contact_path(contact),
                      class: "text-xs text-gray-500 hover:text-gray-700 font-medium" %>
                <%= button_to "Delete", contact_path(contact), method: :delete,
                      data: { action: "click->confirm#open",
                              confirm_message_param: "Remove \"#{contact.display_name}\"?" },
                      class: "text-xs text-red-500 hover:text-red-700 font-medium bg-transparent border-0 cursor-pointer p-0" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="text-center py-16 text-sm text-gray-400">
      <% if @query.present? %>
        <p>No contacts match "<%= @query %>".</p>
        <%= link_to "Clear search", contacts_path, class: "text-indigo-600 hover:text-indigo-800 font-medium mt-2 inline-block" %>
      <% else %>
        <p class="mb-3">No contacts yet.</p>
        <%= link_to "Add the first contact", new_contact_path,
              class: "text-indigo-600 hover:text-indigo-800 font-medium" %>
      <% end %>
    </div>
  <% end %>
</div>
