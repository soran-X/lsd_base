<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Territories</h1>
    <p class="text-sm text-gray-500 mt-0.5">Rights territory codes used in subagent records.</p>
  </div>
  <%= link_to "+ New Territory", new_territory_path,
        class: "inline-flex items-center px-4 py-2 bg-indigo-600 text-white text-sm font-medium
                rounded-lg hover:bg-indigo-700 transition-colors" %>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
  <% if @territories.any? %>
    <table class="min-w-full divide-y divide-gray-100">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Name</th>
          <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Subagents</th>
          <th class="relative px-5 py-3"><span class="sr-only">Actions</span></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @territories.each do |territory| %>
          <tr class="hover:bg-gray-50 transition-colors">
            <td class="px-5 py-3 text-sm font-medium text-gray-900"><%= territory.name %></td>
            <td class="px-5 py-3 text-sm text-gray-500"><%= territory.company_subagents.count %></td>
            <td class="px-5 py-3 text-right text-sm whitespace-nowrap">
              <%= link_to "Edit", edit_territory_path(territory),
                    class: "text-indigo-600 hover:text-indigo-800 font-medium mr-4" %>
              <%= button_to "Delete", territory_path(territory), method: :delete,
                    data: { action: "click->confirm#open",
                            confirm_message_param: "Delete territory \"#{territory.name}\"?" },
                    class: "text-red-500 hover:text-red-700 font-medium bg-transparent border-0
                            cursor-pointer p-0 text-sm" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="px-5 py-12 text-center text-sm text-gray-400 italic">No territories yet.</p>
  <% end %>
</div>
