<% content_for :title, "#{@site_setting.key} — ClinicDev" %>

<div class="mb-6">
  <div class="flex items-center gap-2 text-sm text-gray-500 mb-2">
    <%= link_to "Site Settings", site_settings_path, class: "hover:text-gray-700" %>
    <span>/</span>
    <span class="text-gray-900 font-mono"><%= @site_setting.key %></span>
  </div>
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-gray-900 font-mono"><%= @site_setting.key %></h1>
    <%= link_to "Edit", edit_site_setting_path(@site_setting),
        class: "inline-flex items-center px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition-colors" %>
  </div>
</div>

<div class="max-w-lg">
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 divide-y divide-gray-100">
    <div class="px-6 py-4 flex justify-between text-sm">
      <span class="font-medium text-gray-500">Key</span>
      <span class="font-mono text-gray-900"><%= @site_setting.key %></span>
    </div>
    <div class="px-6 py-4 text-sm">
      <span class="font-medium text-gray-500">Value</span>
      <p class="text-gray-900 mt-1 whitespace-pre-wrap"><%= @site_setting.value %></p>
    </div>
    <div class="px-6 py-4 flex justify-between text-sm">
      <span class="font-medium text-gray-500">Last Updated</span>
      <span class="text-gray-400"><%= @site_setting.updated_at.strftime("%B %d, %Y at %H:%M") %></span>
    </div>
  </div>
</div>
