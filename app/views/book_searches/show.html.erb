<% content_for :title, "Search Results" %>

<div class="max-w-6xl mx-auto space-y-6">

  <%# Header %>
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-gray-900">Search Results</h1>
    <div class="flex items-center gap-3">
      <%= link_to "New Search", new_book_search_path,
            class: "text-sm text-indigo-600 hover:text-indigo-800 transition-colors" %>
      <%= link_to "Saved Searches", book_searches_path,
            class: "text-sm text-gray-500 hover:text-gray-700 transition-colors" %>
    </div>
  </div>

  <%# Results count %>
  <div class="text-sm text-gray-500">
    <% count = @results.size %>
    Found <strong class="text-gray-800"><%= count %></strong>
    <%= "book".pluralize(count) %>
  </div>

  <%# Results table %>
  <% if @results.any? %>
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-100 bg-gray-50">
            <th class="px-4 py-3 text-left font-semibold text-gray-600">Title</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-600 hidden md:table-cell">Author(s)</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-600 hidden sm:table-cell">Status</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-600 hidden lg:table-cell">Updated</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @results.each do |book| %>
            <tr class="hover:bg-gray-50 transition-colors">
              <td class="px-4 py-3">
                <%= link_to book_path(book),
                      class: "font-medium text-indigo-600 hover:text-indigo-800 transition-colors" do %>
                  <%= book.title %>
                  <% if book.subtitle.present? %>
                    <span class="text-gray-400 font-normal">: <%= book.subtitle %></span>
                  <% end %>
                  <% if book.confidential? %>
                    <span class="ml-1.5 text-xs bg-amber-100 text-amber-700 px-1.5 py-0.5 rounded">Confidential</span>
                  <% end %>
                <% end %>
              </td>
              <td class="px-4 py-3 text-gray-500 hidden md:table-cell">
                <%= book.display_authors.presence || "—" %>
              </td>
              <td class="px-4 py-3 hidden sm:table-cell">
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
                             <%= book_status_badge_classes(book.status) %>">
                  <%= book.status.humanize %>
                </span>
              </td>
              <td class="px-4 py-3 text-gray-400 text-xs hidden lg:table-cell">
                <%= book.updated_at.strftime("%b %-d, %Y") %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-12 text-center text-gray-400">
      No books matched your search criteria.
    </div>
  <% end %>

  <%# Re-run / Refine search form %>
  <details class="bg-white rounded-2xl border border-gray-200 shadow-sm">
    <summary class="px-6 py-4 cursor-pointer text-sm font-medium text-gray-700 hover:text-gray-900
                    list-none flex items-center justify-between">
      <span>Refine this search</span>
      <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
      </svg>
    </summary>
    <div class="px-8 pb-8 pt-0 border-t border-gray-100">
      <%= render "form",
            book_search:          @book_search,
            genres:               @genres,
            sub_genres:           @sub_genres,
            client_types:         @client_types,
            saved_authors:        @saved_authors,
            saved_scouts:         @saved_scouts,
            saved_readers:        @saved_readers,
            saved_agencies:       @saved_agencies,
            saved_film_agencies:  @saved_film_agencies,
            saved_publishers:     @saved_publishers,
            saved_editors:        @saved_editors,
            saved_rights_holders: @saved_rights_holders,
            saved_agents:         @saved_agents,
            saved_film_agents:    @saved_film_agents,
            saved_ca_companies:   @saved_ca_companies,
            saved_ca_contacts:    @saved_ca_contacts %>
    </div>
  </details>

</div>
