<div data-user-id="<%= message.user_id %>" class="flex">
  <div class="max-w-[75%]">
    <p data-sender-name class="text-xs text-gray-400 mb-1 ml-1"><%= message.user.display_name %></p>
    <div data-bubble class="rounded-2xl px-4 py-2.5 text-sm">
      <p class="whitespace-pre-wrap break-words"><%= message.body %></p>
    </div>
    <p data-time class="text-xs text-gray-300 mt-1"><%= message.created_at.strftime("%H:%M") %></p>
  </div>
</div>
