<% content_for :title, "Edit Report — #{@report.title}" %>

<div class="mb-6">
  <div class="flex items-center gap-2 text-sm text-gray-500 mb-2">
    <%= link_to "Reports", reports_path, class: "hover:text-gray-700" %>
    <span>/</span>
    <%= link_to @report.title, report_path(@report), class: "hover:text-gray-700 truncate max-w-xs" %>
    <span>/</span>
    <span class="text-gray-900">Edit</span>
  </div>
  <h1 class="text-2xl font-bold text-gray-900">Edit Report</h1>
</div>

<%= render "reports/form", report: @report, preloaded_books: @report.books.includes(:credited_authors) %>
