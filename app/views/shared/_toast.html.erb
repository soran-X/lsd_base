<div data-controller="toast"
     style="opacity:0;transform:translateX(1rem)"
     class="bg-white rounded-xl shadow-lg border border-gray-200 px-4 py-3 w-72 flex items-start gap-3 pointer-events-auto">
  <div class="w-8 h-8 rounded-full flex items-center justify-center text-white text-xs font-semibold flex-shrink-0" style="background-color:var(--color-tertiary)">
    <%= toast_message.user.initials %>
  </div>
  <div class="flex-1 min-w-0">
    <p class="text-sm font-semibold text-gray-900"><%= toast_message.user.display_name %></p>
    <p class="text-xs text-gray-500 truncate mt-0.5"><%= toast_message.body %></p>
  </div>
  <button data-action="toast#dismiss" class="text-gray-400 hover:text-gray-600 text-xl leading-none flex-shrink-0">&times;</button>
</div>
