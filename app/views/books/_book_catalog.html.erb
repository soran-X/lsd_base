<%# Catalog-style book entry ─────────────────────────────────────────────── %>
<% publisher = book.book_companies.find(&:publisher?)&.company %>
<% pub_year  = [book.publication_season&.slice(0, 3), book.publication_year].compact_blank.join(" ") %>

<div class="catalog-card group flex items-start gap-6 px-8 py-7 hover:bg-stone-50 transition-colors">

  <%# ── Main content ─────────────────────────────────────────────────────── %>
  <div class="flex-1 min-w-0">

    <%# ── Title block ────────────────────────────────────────────────────── %>
    <div class="mb-3">
      <div class="flex flex-wrap items-baseline gap-2 mb-1">
        <%= link_to book_path(book),
              class: "text-lg font-semibold text-gray-900 hover:underline leading-snug" do %>
          <%= book.title %>
        <% end %>
        <% if book.lead_title? %>
          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-700 shrink-0">
            Lead Title
          </span>
        <% end %>
        <% if book.confidential? %>
          <span class="inline-flex items-center gap-0.5 px-2 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-700 shrink-0">
            <svg class="w-3 h-3" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
            Private
          </span>
        <% end %>
      </div>
      <% if book.subtitle.present? %>
        <p class="text-sm text-gray-500 italic leading-snug"><%= book.subtitle %></p>
      <% end %>
    </div>

    <%# ── Authors + translators ──────────────────────────────────────────── %>
    <% if book.credited_authors.any? || book.translators.any? %>
      <div class="mb-4 space-y-1">
        <% if book.credited_authors.any? %>
          <p class="text-sm text-gray-700">
            <% book.credited_authors.each_with_index do |a, i| %>
              <%= link_to a.display_name, author_path(a),
                    class: "font-medium hover:underline" %><%= i < book.credited_authors.size - 1 ? " · " : "" %>
            <% end %>
          </p>
        <% end %>
        <% if book.translators.any? %>
          <p class="text-sm text-gray-500">
            Translated by
            <% book.translators.each_with_index do |t, i| %>
              <%= link_to t.display_name, author_path(t),
                    class: "text-gray-600 hover:underline" %><%= i < book.translators.size - 1 ? " · " : "" %>
            <% end %>
          </p>
        <% end %>
      </div>
    <% end %>

    <%# ── Synopsis ───────────────────────────────────────────────────────── %>
    <% if book.synopsis.present? %>
      <div class="trix-content text-sm leading-relaxed text-gray-700 mb-5">
        <%= trix_sanitize book.synopsis %>
      </div>
    <% end %>

    <%# ── Genre / Subgenre / Client Type tags ────────────────────────────── %>
    <% all_tags = book.genres.ordered.map { |g| [g.name, "bg-emerald-50 text-emerald-800 border-emerald-200"] } +
                  book.sub_genres.ordered.map { |sg| [sg.name, "bg-amber-50 text-amber-800 border-amber-200"] } +
                  book.client_types.ordered.map { |ct| [ct.name, "bg-rose-50 text-rose-800 border-rose-200"] } %>
    <% if all_tags.any? %>
      <div class="flex flex-wrap gap-1.5 mb-5">
        <% all_tags.each do |name, css| %>
          <span class="inline-flex px-2.5 py-0.5 rounded-full text-xs font-medium border <%= css %>">
            <%= name %>
          </span>
        <% end %>
      </div>
    <% end %>

    <%# ── Meta footer: scout · publisher · year · updated · status ────────── %>
    <div class="flex flex-wrap items-center gap-x-5 gap-y-1.5 text-xs text-gray-400
                border-t border-gray-100 pt-4">
      <% if book.primary_scout.present? %>
        <span class="flex items-center gap-1.5 text-gray-500">
          <svg class="w-3.5 h-3.5 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
          <%= book.primary_scout.display_name %>
        </span>
      <% end %>
      <% if publisher.present? %>
        <span class="flex items-center gap-1.5 text-gray-500">
          <svg class="w-3.5 h-3.5 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 21H5a2 2 0 01-2-2V7l7-7h9a2 2 0 012 2v17z"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 2v6h6"/>
          </svg>
          <%= publisher.name %>
        </span>
      <% end %>
      <% if pub_year.present? %>
        <span class="text-gray-500"><%= pub_year %></span>
      <% end %>
      <span class="flex items-center gap-1" title="<%= book.updated_at.strftime("%B %-d, %Y at %H:%M") %>">
        <svg class="w-3.5 h-3.5 text-gray-300 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        Updated <%= time_ago_in_words(book.updated_at) %> ago<% if book.last_updated_by.present? %> · <%= book.last_updated_by.display_name %><% end %>
      </span>
      <% css = { "draft" => "bg-gray-100 text-gray-600", "active" => "bg-green-100 text-green-700",
                 "inactive" => "bg-yellow-100 text-yellow-700", "acquired" => "bg-blue-100 text-blue-700",
                 "passed" => "bg-red-100 text-red-600" }[book.status] || "bg-gray-100 text-gray-600" %>
      <span class="inline-flex px-2 py-0.5 rounded-full font-medium <%= css %>">
        <%= book.status&.humanize || "Draft" %>
      </span>
    </div>

  </div>

  <%# ── Actions ──────────────────────────────────────────────────────────── %>
  <div class="shrink-0 flex flex-col gap-2 pt-1 opacity-0 group-hover:opacity-100 transition-opacity">
    <%= link_to "Show", book_path(book),
          class: "inline-flex items-center px-3 py-1.5 bg-white text-gray-700 text-xs font-medium rounded-lg border border-gray-200 hover:bg-gray-50 transition-colors" %>
    <%= link_to "Edit", edit_book_path(book),
          class: "inline-flex items-center px-3 py-1.5 bg-white text-gray-700 text-xs font-medium rounded-lg border border-gray-200 hover:bg-gray-50 transition-colors" %>
  </div>

</div>
