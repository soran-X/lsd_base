<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Books</h1>
  <%= link_to "New Book", new_book_path,
        class: "inline-flex items-center px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition-colors" %>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
  <table class="w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="text-xs font-medium text-gray-500 uppercase tracking-wider px-6 py-3 text-left">Title</th>
        <th class="text-xs font-medium text-gray-500 uppercase tracking-wider px-6 py-3 text-left">Author ID</th>
        <th class="text-xs font-medium text-gray-500 uppercase tracking-wider px-6 py-3 text-left">Published</th>
        <th class="text-xs font-medium text-gray-500 uppercase tracking-wider px-6 py-3 text-right">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% @books.each do |book| %>
        <tr class="bg-white hover:bg-gray-50 transition-colors">
          <td class="px-6 py-4 text-sm text-gray-900 font-medium"><%= book.title %></td>
          <td class="px-6 py-4 text-sm text-gray-900"><%= book.author_id %></td>
          <td class="px-6 py-4 text-sm text-gray-900">
            <%= book.published_at&.strftime("%B %-d, %Y") %>
          </td>
          <td class="px-6 py-4 text-sm text-right">
            <div class="inline-flex items-center gap-2">
              <%= link_to "Show", book_path(book),
                    class: "inline-flex items-center px-4 py-2 bg-white text-gray-700 text-sm font-medium rounded-lg border border-gray-200 hover:bg-gray-50 transition-colors" %>
              <%= link_to "Edit", edit_book_path(book),
                    class: "inline-flex items-center px-4 py-2 bg-white text-gray-700 text-sm font-medium rounded-lg border border-gray-200 hover:bg-gray-50 transition-colors" %>
              <%= button_to "Delete", book_path(book),
                    method: :delete,
                    data: { turbo_confirm: "Are you sure you want to delete \"#{book.title}\"?" },
                    class: "inline-flex items-center px-4 py-2 bg-red-600 text-white text-sm font-medium rounded-lg hover:bg-red-700 transition-colors" %>
            </div>
          </td>
        </tr>
      <% end %>

      <% if @books.empty? %>
        <tr>
          <td colspan="4" class="px-6 py-12 text-center text-sm text-gray-500">
            No books found. <%= link_to "Add the first one", new_book_path, class: "text-indigo-600 hover:underline font-medium" %>.
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
