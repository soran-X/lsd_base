<%# Film Info card — used in books/show Film tab %>
<div class="rounded-lg border border-gray-200 overflow-hidden">
  <div class="bg-gray-50 px-4 py-2.5 border-b border-gray-200 flex items-center gap-3">
    <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Film Info</p>
    <% if ft.film_flag.present? %>
      <% badge_color = ft.film_flag == "Out for Film" ? "bg-red-100 text-red-700" : "bg-amber-100 text-amber-700" %>
      <span class="inline-flex px-2.5 py-0.5 rounded-full text-xs font-medium <%= badge_color %>"><%= ft.film_flag %></span>
    <% end %>
    <% if ft.enable_red_text? %>
      <span class="inline-flex px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-50 text-red-600 border border-red-200">Red Text</span>
    <% end %>
  </div>
  <dl class="divide-y divide-gray-100 px-4">
    <% if ft.film_option_date.present? %>
      <div class="py-3 grid grid-cols-3 gap-4">
        <dt class="text-sm font-medium text-gray-500">Option Date</dt>
        <dd class="col-span-2 text-sm text-gray-700"><%= ft.film_option_date.strftime("%b %-d, %Y") %></dd>
      </div>
    <% end %>
    <% if ft.film_option.present? %>
      <div class="py-3 grid grid-cols-3 gap-4">
        <dt class="text-sm font-medium text-gray-500">Film Option</dt>
        <dd class="col-span-2 text-sm text-gray-800 leading-relaxed trix-content"><%= trix_sanitize ft.film_option %></dd>
      </div>
    <% end %>
    <% if ft.category.present? %>
      <div class="py-3 grid grid-cols-3 gap-4">
        <dt class="text-sm font-medium text-gray-500">Category</dt>
        <dd class="col-span-2 text-sm text-gray-700"><%= ft.category %></dd>
      </div>
    <% end %>
    <% if ft.comments.present? %>
      <div class="py-3 grid grid-cols-3 gap-4">
        <dt class="text-sm font-medium text-gray-500">Comments</dt>
        <dd class="col-span-2 text-sm text-gray-800 leading-relaxed trix-content"><%= trix_sanitize ft.comments %></dd>
      </div>
    <% end %>
    <% if ft.film_synopsis.present? %>
      <div class="py-3 grid grid-cols-3 gap-4">
        <dt class="text-sm font-medium text-gray-500">Synopsis</dt>
        <dd class="col-span-2 text-sm text-gray-800 leading-relaxed trix-content"><%= trix_sanitize ft.film_synopsis %></dd>
      </div>
    <% end %>
    <% if ft.material.present? %>
      <div class="py-3 grid grid-cols-3 gap-4">
        <dt class="text-sm font-medium text-gray-500">Material</dt>
        <dd class="col-span-2 text-sm text-gray-800 leading-relaxed trix-content"><%= trix_sanitize ft.material %></dd>
      </div>
    <% end %>
    <% if ft.readers_thoughts.present? %>
      <div class="py-3 grid grid-cols-3 gap-4">
        <dt class="text-sm font-medium text-gray-500">Reader's Thoughts</dt>
        <dd class="col-span-2 text-sm text-gray-800 leading-relaxed trix-content"><%= trix_sanitize ft.readers_thoughts %></dd>
      </div>
    <% end %>
    <% if ft.enable_red_text? && ft.red_text.present? %>
      <div class="py-3 grid grid-cols-3 gap-4">
        <dt class="text-sm font-medium text-red-600">Red Text</dt>
        <dd class="col-span-2 text-sm text-red-700 leading-relaxed whitespace-pre-wrap"><%= ft.red_text %></dd>
      </div>
    <% end %>
    <% if ft.film_genres.any? %>
      <div class="py-3 grid grid-cols-3 gap-4">
        <dt class="text-sm font-medium text-gray-500">Film Genres</dt>
        <dd class="col-span-2">
          <div class="flex flex-wrap gap-1.5">
            <% ft.film_genres.each do |g| %>
              <span class="inline-flex px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-50 text-purple-800 border border-purple-200">
                <%= g.name %>
              </span>
            <% end %>
          </div>
        </dd>
      </div>
    <% end %>
  </dl>
</div>
