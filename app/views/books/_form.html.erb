<%= form_with model: book, class: "space-y-0" do |f| %>
  <%# ── Errors ──────────────────────────────────────────────────────────── %>
  <% if book.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6 text-sm text-red-700">
      <p class="font-semibold mb-1"><%= pluralize(book.errors.count, "error") %> prevented this book from being saved:</p>
      <ul class="list-disc list-inside space-y-0.5">
        <% book.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
      </ul>
    </div>
  <% end %>

  <%# ══ SAVE (top) ════════════════════════════════════════════════════════= %>
  <div class="flex items-center gap-3 mb-4 flex-wrap">
    <%= f.submit class: "inline-flex items-center px-5 py-2.5 bg-indigo-600 text-white text-sm
                          font-medium rounded-lg hover:bg-indigo-700 transition-colors cursor-pointer" %>
    <%= link_to "Cancel", books_path,
          class: "inline-flex items-center px-4 py-2 bg-white text-gray-700 text-sm
                  font-medium rounded-lg border border-gray-200 hover:bg-gray-50 transition-colors" %>
    <% if book.persisted? %>
      <span class="text-xs text-gray-400 ml-1">
        Last saved <%= time_ago_in_words(book.updated_at) %> ago<% if book.last_updated_by.present? %> by <strong class="font-medium text-gray-500"><%= book.last_updated_by.display_name %></strong><% end %>
      </span>
    <% end %>
  </div>

  <%# ══ TABS ══════════════════════════════════════════════════════════════= %>
  <div data-controller="tab"
       data-tab-persist-value="book-form-<%= book.persisted? ? book.id : 'new' %>"
       class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">

    <%# Tab bar %>
    <div class="border-b border-gray-200 px-6">
      <nav class="-mb-px flex gap-6 overflow-x-auto" role="tablist" aria-label="Book sections">
        <% [
          ["info",    "Book Info"],
          ["notes",   "Notes"],
          ["coverage","Scout Coverage"],
          ["film",    "Film"],
          ["report",  "Reader's Report"],
        ].each do |key, label| %>
          <button type="button"
                  role="tab"
                  data-tab-target="tab"
                  data-tab="<%= key %>"
                  data-action="click->tab#switch"
                  class="whitespace-nowrap border-b-2 py-4 px-1 text-sm transition-colors duration-150
                         border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300">
            <%= label %>
          </button>
        <% end %>
      </nav>
    </div>

    <%# ── Tab: Book Info ──────────────────────────────────────────────────── %>
    <div data-tab-target="panel" data-tab="info" class="px-6 py-6 space-y-6">

      <%# ══ Book Information ══════════════════════════════════════════════════ %>
      <div class="rounded-lg border border-gray-200 overflow-hidden">
        <div class="bg-gray-50 px-4 py-2.5 border-b border-gray-200">
          <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Book Information</p>
        </div>
        <div class="p-4 space-y-4">

          <%# Title row + Private toggle %>
          <div class="flex gap-4 items-end">
            <div class="flex-1">
              <%= f.label :title, class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= f.text_field :title, placeholder: "Title",
                    class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                            focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
            </div>

            <%# Private — padlock toggle %>
            <div class="shrink-0 pb-0.5">
              <label class="flex items-center gap-2 cursor-pointer select-none">
                <%= f.check_box :confidential, class: "sr-only peer" %>
                <%# Toggle track (thumb via after: pseudo-element) %>
                <div class="relative w-11 h-6 rounded-full transition-colors bg-gray-200
                            peer-checked:bg-amber-500
                            after:content-[''] after:absolute after:top-0.5 after:left-0.5
                            after:h-5 after:w-5 after:bg-white after:rounded-full after:shadow
                            after:transition-transform peer-checked:after:translate-x-5"></div>
                <%# Unlocked padlock — visible when not private %>
                <svg class="w-4 h-4 text-gray-400 peer-checked:hidden" xmlns="http://www.w3.org/2000/svg"
                     viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                  <path d="M7 11V7a5 5 0 0 1 9.9-1"/>
                </svg>
                <%# Locked padlock — visible when private %>
                <svg class="w-4 h-4 text-amber-600 hidden peer-checked:block" xmlns="http://www.w3.org/2000/svg"
                     viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                  <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
                <span class="text-sm font-medium text-gray-700">Private</span>
              </label>
              <p class="mt-0.5 text-xs text-gray-400 pl-13">Hide from clients</p>
            </div>
          </div>

          <%# Subtitle + Old Title %>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <%= f.label :subtitle, class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= f.text_field :subtitle, placeholder: "Subtitle (optional)",
                    class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                            focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
            </div>
            <div>
              <%= f.label :old_title, "Old Title", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= f.text_field :old_title, placeholder: "Previous title (optional)",
                    class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                            focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
            </div>
          </div>

          <%# Authors + Translators side by side %>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <%= render "books/author_combobox",
                  label:      "Authors",
                  role:       "Author",
                  field_name: "book[author_ids][]",
                  selected:   book.persisted? ? book.credited_authors.to_a : [] %>
            <%= render "books/author_combobox",
                  label:      "Translators",
                  role:       "Translator",
                  field_name: "book[translator_ids][]",
                  selected:   book.persisted? ? book.translators.to_a : [],
                  color:      "amber" %>
          </div>

          <%# Genre + Subgenre — side by side %>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

            <%# Genre %>
            <% initial_genres = book.persisted? ? book.genres.ordered.map { |g| { id: g.id, name: g.name } } : [] %>
            <div data-controller="tag-select"
                 data-tag-select-selected-value="<%= initial_genres.to_json %>"
                 data-tag-select-field-name-value="book[genre_ids][]"
                 data-tag-select-color-value="emerald">
              <p class="block text-sm font-medium text-gray-700 mb-2">Genre</p>
              <div data-tag-select-target="tags" class="flex flex-wrap gap-1.5 mb-2 min-h-[2rem]"></div>
              <div data-tag-select-target="inputs"></div>
              <select data-action="change->tag-select#add"
                      data-tag-select-target="select"
                      class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                             focus:outline-none focus:ring-2 focus:ring-indigo-500 bg-white">
                <option value="">Add a genre…</option>
                <% Genre.ordered.each do |g| %>
                  <option value="<%= g.id %>"><%= g.name %></option>
                <% end %>
              </select>
            </div>

            <%# Subgenre (independent of genre) %>
            <% initial_subgenres = book.persisted? ? book.sub_genres.ordered.map { |sg| { id: sg.id, name: sg.name } } : [] %>
            <div data-controller="tag-select"
                 data-tag-select-selected-value="<%= initial_subgenres.to_json %>"
                 data-tag-select-field-name-value="book[sub_genre_ids][]"
                 data-tag-select-color-value="amber">
              <p class="block text-sm font-medium text-gray-700 mb-2">Subgenre</p>
              <div data-tag-select-target="tags" class="flex flex-wrap gap-1.5 mb-2 min-h-[2rem]"></div>
              <div data-tag-select-target="inputs"></div>
              <select data-action="change->tag-select#add"
                      data-tag-select-target="select"
                      class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                             focus:outline-none focus:ring-2 focus:ring-indigo-500 bg-white">
                <option value="">Add a subgenre…</option>
                <% SubGenre.ordered.each do |sg| %>
                  <option value="<%= sg.id %>"><%= sg.name %></option>
                <% end %>
              </select>
            </div>

          </div>

          <%# Client Type (multiple — tag combobox) %>
          <% initial_client_types = book.persisted? ? book.client_types.ordered.map { |ct| { id: ct.id, name: ct.name } } : [] %>
          <div data-controller="tag-select"
               data-tag-select-selected-value="<%= initial_client_types.to_json %>"
               data-tag-select-field-name-value="book[client_type_ids][]"
               data-tag-select-color-value="rose">
            <p class="block text-sm font-medium text-gray-700 mb-2">Client Type</p>
            <p class="text-xs text-gray-400 mb-2">Clients only see books matching their subscription type.</p>
            <div data-tag-select-target="tags" class="flex flex-wrap gap-1.5 mb-2 min-h-[2rem]"></div>
            <div data-tag-select-target="inputs"></div>
            <select data-action="change->tag-select#add"
                    data-tag-select-target="select"
                    class="block w-full sm:w-72 rounded-lg border border-gray-300 px-3 py-2 text-sm
                           focus:outline-none focus:ring-2 focus:ring-indigo-500 bg-white">
              <option value="">Add a client type…</option>
              <% ClientType.ordered.each do |ct| %>
                <option value="<%= ct.id %>"><%= ct.name %></option>
              <% end %>
            </select>
          </div>

          <%# Lead Title + Still Tracking toggles %>
          <div class="flex flex-wrap gap-6 pt-1">
            <label class="flex items-center gap-3 cursor-pointer select-none">
              <%= f.check_box :lead_title, class: "sr-only peer" %>
              <div class="relative w-11 h-6 rounded-full transition-colors bg-gray-200
                          peer-checked:bg-indigo-600
                          after:content-[''] after:absolute after:top-0.5 after:left-0.5
                          after:h-5 after:w-5 after:bg-white after:rounded-full after:shadow
                          after:transition-transform peer-checked:after:translate-x-5"></div>
              <span class="text-sm font-medium text-gray-700">Lead Title</span>
            </label>

            <label class="flex items-center gap-3 cursor-pointer select-none">
              <%= f.check_box :tracking_material, class: "sr-only peer" %>
              <div class="relative w-11 h-6 rounded-full transition-colors bg-gray-200
                          peer-checked:bg-indigo-600
                          after:content-[''] after:absolute after:top-0.5 after:left-0.5
                          after:h-5 after:w-5 after:bg-white after:rounded-full after:shadow
                          after:transition-transform peer-checked:after:translate-x-5"></div>
              <span class="text-sm font-medium text-gray-700">Still tracking material?</span>
            </label>
          </div>

        </div>
      </div>

      <%# ══ Administrative ════════════════════════════════════════════════════ %>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <%= f.label :status, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.select :status,
                Book.statuses.keys.map { |s| [s.humanize, s] },
                { selected: book.status || "draft" },
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                        focus:outline-none focus:ring-2 focus:ring-indigo-500 bg-white" %>
        </div>
      </div>

      <%# ── Scouts + Schedule ──────────────────────────────────────────────── %>
      <div class="rounded-lg border border-gray-200 overflow-hidden">
        <div class="grid grid-cols-1 lg:grid-cols-2 divide-y lg:divide-y-0 lg:divide-x divide-gray-200">

          <%# Scouts %>
          <div class="p-4">
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">Scout Assignment</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              <div>
                <%= f.label :primary_scout_id, "Primary",
                      class: "block text-xs font-medium text-gray-600 mb-1" %>
                <%= f.select :primary_scout_id,
                      User.order(:last_name, :first_name).map { |u| [u.display_name, u.id] },
                      { include_blank: "— none —", selected: book.primary_scout_id },
                      class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                              focus:outline-none focus:ring-2 focus:ring-indigo-500 bg-white" %>
              </div>
              <div>
                <%= f.label :secondary_scout_id, "Secondary",
                      class: "block text-xs font-medium text-gray-600 mb-1" %>
                <%= f.select :secondary_scout_id,
                      User.order(:last_name, :first_name).map { |u| [u.display_name, u.id] },
                      { include_blank: "— none —", selected: book.secondary_scout_id },
                      class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                              focus:outline-none focus:ring-2 focus:ring-indigo-500 bg-white" %>
              </div>
            </div>
          </div>

          <%# Schedule %>
          <div class="p-4">
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">Schedule</p>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <%= f.label :delivery_date, "Delivery",
                      class: "block text-xs font-medium text-gray-600 mb-1" %>
                <%= f.date_field :delivery_date,
                      class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                              focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
              </div>
              <div>
                <%= f.label :followup_date, "Follow-up",
                      class: "block text-xs font-medium text-gray-600 mb-1" %>
                <%= f.date_field :followup_date,
                      class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                              focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
              </div>
              <div>
                <%= f.label :publication_season, "Season",
                      class: "block text-xs font-medium text-gray-600 mb-1" %>
                <%= f.select :publication_season,
                      [["— none —", ""]] + Book::SEASONS,
                      { selected: book.publication_season },
                      class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                              focus:outline-none focus:ring-2 focus:ring-indigo-500 bg-white" %>
              </div>
              <div>
                <%= f.label :publication_year, "Year",
                      class: "block text-xs font-medium text-gray-600 mb-1" %>
                <%= f.select :publication_year,
                      [["— none —", ""]] + Book::PUBLICATION_YEARS.map { |y| [y.to_s, y] },
                      { selected: book.publication_year },
                      class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                              focus:outline-none focus:ring-2 focus:ring-indigo-500 bg-white" %>
              </div>
            </div>
          </div>

        </div>
      </div>

      <%# Synopsis %>
      <div>
        <%= f.label :synopsis, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <div data-controller="rich-text"
             data-rich-text-name-value="book[synopsis]"
             data-rich-text-value-value="<%= book.synopsis.to_s %>"></div>
      </div>

    </div><%# end info panel %>

    <%# ── Tab: Notes ──────────────────────────────────────────────────────── %>
    <div data-tab-target="panel" data-tab="notes" class="hidden px-6 py-6 space-y-6">

      <%# ── Material Notes ─────────────────────────────────────────────── %>
      <div class="rounded-lg border border-gray-200 overflow-hidden" data-controller="nested-form">
        <div class="bg-gray-50 px-4 py-2.5 border-b border-gray-200 flex items-center justify-between">
          <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Material Notes</p>
          <label class="flex items-center gap-2 cursor-pointer select-none">
            <%= f.check_box :material_to_read, class: "sr-only peer" %>
            <div class="relative w-9 h-5 rounded-full transition-colors bg-gray-200
                        peer-checked:bg-indigo-600
                        after:content-[''] after:absolute after:top-0.5 after:left-0.5
                        after:h-4 after:w-4 after:bg-white after:rounded-full after:shadow
                        after:transition-transform peer-checked:after:translate-x-4"></div>
            <span class="text-xs font-medium text-gray-600">To Read</span>
          </label>
        </div>

        <div class="divide-y divide-gray-100" data-nested-form-target="container">
          <%= f.fields_for :reading_materials do |rm| %>
            <div class="p-4 grid grid-cols-1 sm:grid-cols-4 gap-3 items-end" data-nested-form-row>
              <%= rm.hidden_field :id %>
              <%= rm.hidden_field :_destroy, value: "0" %>
              <div>
                <%= rm.label :material, class: "block text-xs font-medium text-gray-600 mb-1" %>
                <%= rm.text_field :material,
                      class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                              focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
              </div>
              <div>
                <%= rm.label :reader, class: "block text-xs font-medium text-gray-600 mb-1" %>
                <%= rm.text_field :reader,
                      class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                              focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
              </div>
              <div>
                <%= rm.label :number_of_pages, "Pages", class: "block text-xs font-medium text-gray-600 mb-1" %>
                <%= rm.number_field :number_of_pages,
                      class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                              focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
              </div>
              <div class="flex gap-2 items-end">
                <div class="flex-1">
                  <%= rm.label :date, class: "block text-xs font-medium text-gray-600 mb-1" %>
                  <%= rm.date_field :date,
                        class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                                focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
                </div>
                <button type="button" data-action="nested-form#remove"
                        class="shrink-0 text-xs text-red-400 hover:text-red-600 pb-2.5 transition-colors">Remove</button>
              </div>
            </div>
          <% end %>
        </div>

        <template data-nested-form-target="template">
          <%= f.fields_for :reading_materials, ReadingMaterial.new, child_index: "__INDEX__" do |rm| %>
            <div class="p-4 grid grid-cols-1 sm:grid-cols-4 gap-3 items-end" data-nested-form-row>
              <%= rm.hidden_field :id %>
              <%= rm.hidden_field :_destroy, value: "0" %>
              <div>
                <%= rm.label :material, class: "block text-xs font-medium text-gray-600 mb-1" %>
                <%= rm.text_field :material,
                      class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                              focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
              </div>
              <div>
                <%= rm.label :reader, class: "block text-xs font-medium text-gray-600 mb-1" %>
                <%= rm.text_field :reader,
                      class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                              focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
              </div>
              <div>
                <%= rm.label :number_of_pages, "Pages", class: "block text-xs font-medium text-gray-600 mb-1" %>
                <%= rm.number_field :number_of_pages,
                      class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                              focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
              </div>
              <div class="flex gap-2 items-end">
                <div class="flex-1">
                  <%= rm.label :date, class: "block text-xs font-medium text-gray-600 mb-1" %>
                  <%= rm.date_field :date,
                        class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                                focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
                </div>
                <button type="button" data-action="nested-form#remove"
                        class="shrink-0 text-xs text-red-400 hover:text-red-600 pb-2.5 transition-colors">Remove</button>
              </div>
            </div>
          <% end %>
        </template>

        <div class="px-4 py-3 bg-gray-50 border-t border-gray-100">
          <button type="button" data-action="nested-form#add"
                  class="text-xs font-medium text-indigo-600 hover:text-indigo-800 transition-colors">
            + Add Material Note
          </button>
        </div>
      </div>

      <%# ── Client Activity Notes ──────────────────────────────────────── %>
      <div class="rounded-lg border border-gray-200 overflow-hidden" data-controller="nested-form">
        <div class="bg-gray-50 px-4 py-2.5 border-b border-gray-200">
          <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Client Activity Notes</p>
        </div>

        <div class="divide-y divide-gray-100" data-nested-form-target="container">
          <%= f.fields_for :client_activities do |ca| %>
            <div class="p-4 space-y-3" data-nested-form-row>
              <%= ca.hidden_field :id %>
              <%= ca.hidden_field :_destroy, value: "0" %>
              <div class="grid grid-cols-1 sm:grid-cols-4 gap-3 items-end">
                <div>
                  <%= ca.label :date, class: "block text-xs font-medium text-gray-600 mb-1" %>
                  <%= ca.date_field :date,
                        class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                                focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
                </div>
                <div>
                  <%= ca.label :activity_type, "Type", class: "block text-xs font-medium text-gray-600 mb-1" %>
                  <%= ca.select :activity_type,
                        [["— type —", ""], "ACQ", "BOI", "OFF", "TD"],
                        { selected: ca.object.activity_type },
                        class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                                focus:outline-none focus:ring-2 focus:ring-indigo-500 bg-white" %>
                </div>
                <div>
                  <%= ca.label :company_id, "Company", class: "block text-xs font-medium text-gray-600 mb-1" %>
                  <%= ca.select :company_id,
                        Company.kept.order(:name).map { |c| [c.name, c.id] },
                        { include_blank: "— none —", selected: ca.object.company_id },
                        class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                                focus:outline-none focus:ring-2 focus:ring-indigo-500 bg-white" %>
                </div>
                <div class="flex gap-2 items-end">
                  <div class="flex-1">
                    <%= ca.label :contact_id, "Contact", class: "block text-xs font-medium text-gray-600 mb-1" %>
                    <%= ca.select :contact_id,
                          Contact.kept.order(:last_name, :first_name).map { |c| ["#{c.last_name}, #{c.first_name}", c.id] },
                          { include_blank: "— none —", selected: ca.object.contact_id },
                          class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                                  focus:outline-none focus:ring-2 focus:ring-indigo-500 bg-white" %>
                  </div>
                  <button type="button" data-action="nested-form#remove"
                          class="shrink-0 text-xs text-red-400 hover:text-red-600 pb-2.5 transition-colors">Remove</button>
                </div>
              </div>
              <div>
                <%= ca.label :content, class: "block text-xs font-medium text-gray-600 mb-1" %>
                <div data-controller="rich-text"
                     data-rich-text-name-value="<%= ca.object_name %>[content]"
                     data-rich-text-value-value="<%= ca.object.content.to_s %>"></div>
              </div>
            </div>
          <% end %>
        </div>

        <template data-nested-form-target="template">
          <%= f.fields_for :client_activities, ClientActivity.new, child_index: "__INDEX__" do |ca| %>
            <div class="p-4 space-y-3" data-nested-form-row>
              <%= ca.hidden_field :id %>
              <%= ca.hidden_field :_destroy, value: "0" %>
              <div class="grid grid-cols-1 sm:grid-cols-4 gap-3 items-end">
                <div>
                  <%= ca.label :date, class: "block text-xs font-medium text-gray-600 mb-1" %>
                  <%= ca.date_field :date,
                        class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                                focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
                </div>
                <div>
                  <%= ca.label :activity_type, "Type", class: "block text-xs font-medium text-gray-600 mb-1" %>
                  <%= ca.select :activity_type,
                        [["— type —", ""], "ACQ", "BOI", "OFF", "TD"],
                        {},
                        class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                                focus:outline-none focus:ring-2 focus:ring-indigo-500 bg-white" %>
                </div>
                <div>
                  <%= ca.label :company_id, "Company", class: "block text-xs font-medium text-gray-600 mb-1" %>
                  <%= ca.select :company_id,
                        Company.kept.order(:name).map { |c| [c.name, c.id] },
                        { include_blank: "— none —" },
                        class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                                focus:outline-none focus:ring-2 focus:ring-indigo-500 bg-white" %>
                </div>
                <div class="flex gap-2 items-end">
                  <div class="flex-1">
                    <%= ca.label :contact_id, "Contact", class: "block text-xs font-medium text-gray-600 mb-1" %>
                    <%= ca.select :contact_id,
                          Contact.kept.order(:last_name, :first_name).map { |c| ["#{c.last_name}, #{c.first_name}", c.id] },
                          { include_blank: "— none —" },
                          class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                                  focus:outline-none focus:ring-2 focus:ring-indigo-500 bg-white" %>
                  </div>
                  <button type="button" data-action="nested-form#remove"
                          class="shrink-0 text-xs text-red-400 hover:text-red-600 pb-2.5 transition-colors">Remove</button>
                </div>
              </div>
              <div>
                <%= ca.label :content, class: "block text-xs font-medium text-gray-600 mb-1" %>
                <div data-controller="rich-text"
                     data-rich-text-name-value="<%= ca.object_name %>[content]"
                     data-rich-text-value-value=""></div>
              </div>
            </div>
          <% end %>
        </template>

        <div class="px-4 py-3 bg-gray-50 border-t border-gray-100">
          <button type="button" data-action="nested-form#add"
                  class="text-xs font-medium text-indigo-600 hover:text-indigo-800 transition-colors">
            + Add Client Activity
          </button>
        </div>
      </div>

      <%# ── Memo History ────────────────────────────────────────────────── %>
      <div class="rounded-lg border border-gray-200 overflow-hidden" data-controller="nested-form">
        <div class="bg-gray-50 px-4 py-2.5 border-b border-gray-200">
          <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Memo History</p>
        </div>

        <div class="divide-y divide-gray-100" data-nested-form-target="container">
          <%= f.fields_for :book_memos do |bm| %>
            <div class="p-4 space-y-3" data-nested-form-row>
              <%= bm.hidden_field :id %>
              <%= bm.hidden_field :_destroy, value: "0" %>
              <div class="flex gap-3 items-end justify-between">
                <div>
                  <%= bm.label :date, class: "block text-xs font-medium text-gray-600 mb-1" %>
                  <%= bm.date_field :date,
                        class: "block rounded-lg border border-gray-300 px-3 py-2 text-sm
                                focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
                </div>
                <button type="button" data-action="nested-form#remove"
                        class="text-xs text-red-400 hover:text-red-600 pb-2.5 transition-colors">Remove</button>
              </div>
              <div>
                <%= bm.label :note, class: "block text-xs font-medium text-gray-600 mb-1" %>
                <div data-controller="rich-text"
                     data-rich-text-name-value="<%= bm.object_name %>[note]"
                     data-rich-text-value-value="<%= bm.object.note.to_s %>"></div>
              </div>
            </div>
          <% end %>
        </div>

        <template data-nested-form-target="template">
          <%= f.fields_for :book_memos, BookMemo.new, child_index: "__INDEX__" do |bm| %>
            <div class="p-4 space-y-3" data-nested-form-row>
              <%= bm.hidden_field :id %>
              <%= bm.hidden_field :_destroy, value: "0" %>
              <div class="flex gap-3 items-end justify-between">
                <div>
                  <%= bm.label :date, class: "block text-xs font-medium text-gray-600 mb-1" %>
                  <%= bm.date_field :date,
                        class: "block rounded-lg border border-gray-300 px-3 py-2 text-sm
                                focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
                </div>
                <button type="button" data-action="nested-form#remove"
                        class="text-xs text-red-400 hover:text-red-600 pb-2.5 transition-colors">Remove</button>
              </div>
              <div>
                <%= bm.label :note, class: "block text-xs font-medium text-gray-600 mb-1" %>
                <div data-controller="rich-text"
                     data-rich-text-name-value="<%= bm.object_name %>[note]"
                     data-rich-text-value-value=""></div>
              </div>
            </div>
          <% end %>
        </template>

        <div class="px-4 py-3 bg-gray-50 border-t border-gray-100">
          <button type="button" data-action="nested-form#add"
                  class="text-xs font-medium text-indigo-600 hover:text-indigo-800 transition-colors">
            + Add Memo
          </button>
        </div>
      </div>

      <%# ── Archive Notes ───────────────────────────────────────────────── %>
      <div class="rounded-lg border border-gray-200 overflow-hidden" data-controller="nested-form">
        <div class="bg-gray-50 px-4 py-2.5 border-b border-gray-200">
          <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Archive Notes</p>
        </div>

        <div class="divide-y divide-gray-100" data-nested-form-target="container">
          <%= f.fields_for :archive_notes do |an| %>
            <div class="p-4 space-y-3" data-nested-form-row>
              <%= an.hidden_field :id %>
              <%= an.hidden_field :_destroy, value: "0" %>
              <div class="flex gap-3 items-end justify-between">
                <div>
                  <%= an.label :date, class: "block text-xs font-medium text-gray-600 mb-1" %>
                  <%= an.date_field :date,
                        class: "block rounded-lg border border-gray-300 px-3 py-2 text-sm
                                focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
                </div>
                <button type="button" data-action="nested-form#remove"
                        class="text-xs text-red-400 hover:text-red-600 pb-2.5 transition-colors">Remove</button>
              </div>
              <div>
                <%= an.label :note, class: "block text-xs font-medium text-gray-600 mb-1" %>
                <div data-controller="rich-text"
                     data-rich-text-name-value="<%= an.object_name %>[note]"
                     data-rich-text-value-value="<%= an.object.note.to_s %>"></div>
              </div>
            </div>
          <% end %>
        </div>

        <template data-nested-form-target="template">
          <%= f.fields_for :archive_notes, ArchiveNote.new, child_index: "__INDEX__" do |an| %>
            <div class="p-4 space-y-3" data-nested-form-row>
              <%= an.hidden_field :id %>
              <%= an.hidden_field :_destroy, value: "0" %>
              <div class="flex gap-3 items-end justify-between">
                <div>
                  <%= an.label :date, class: "block text-xs font-medium text-gray-600 mb-1" %>
                  <%= an.date_field :date,
                        class: "block rounded-lg border border-gray-300 px-3 py-2 text-sm
                                focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
                </div>
                <button type="button" data-action="nested-form#remove"
                        class="text-xs text-red-400 hover:text-red-600 pb-2.5 transition-colors">Remove</button>
              </div>
              <div>
                <%= an.label :note, class: "block text-xs font-medium text-gray-600 mb-1" %>
                <div data-controller="rich-text"
                     data-rich-text-name-value="<%= an.object_name %>[note]"
                     data-rich-text-value-value=""></div>
              </div>
            </div>
          <% end %>
        </template>

        <div class="px-4 py-3 bg-gray-50 border-t border-gray-100">
          <button type="button" data-action="nested-form#add"
                  class="text-xs font-medium text-indigo-600 hover:text-indigo-800 transition-colors">
            + Add Archive Note
          </button>
        </div>
      </div>

    </div><%# end notes panel %>

    <%# ── Tab: Scout Coverage ─────────────────────────────────────────────── %>
    <div data-tab-target="panel" data-tab="coverage" class="hidden px-6 py-6">
      <div class="text-center py-12 text-sm text-gray-400">
        <svg class="w-10 h-10 mx-auto mb-3 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
        </svg>
        Scout Coverage will appear here once reports are linked to this book.
      </div>
    </div>

    <%# ── Tab: Film ───────────────────────────────────────────────────────── %>
    <div data-tab-target="panel" data-tab="film" class="hidden px-6 py-6">
      <%= f.fields_for :film_tracking do |ft| %>
        <div class="space-y-5">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <%= ft.label :film_option, "Film Option",
                    class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= ft.text_field :film_option,
                    placeholder: "Option status or deal memo",
                    class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                            focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
            </div>
            <div>
              <%= ft.label :category,
                    class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= ft.text_field :category,
                    placeholder: "Feature, Series, Documentary…",
                    class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                            focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
            </div>
          </div>
          <div>
            <%= ft.label :film_synopsis, "Film Synopsis",
                  class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= ft.text_area :film_synopsis, rows: 5,
                  placeholder: "Pitch for the film adaptation…",
                  class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                          focus:outline-none focus:ring-2 focus:ring-indigo-500 resize-y" %>
          </div>
          <div>
            <%= ft.label :readers_thoughts, "Film Notes",
                  class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= ft.text_area :readers_thoughts, rows: 4,
                  placeholder: "Internal notes on film potential…",
                  class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                          focus:outline-none focus:ring-2 focus:ring-indigo-500 resize-y" %>
          </div>
        </div>
      <% end %>
    </div>

    <%# ── Tab: Reader's Report ────────────────────────────────────────────── %>
    <div data-tab-target="panel" data-tab="report" class="hidden px-6 py-6">
      <p class="text-sm text-gray-500 mb-3">Formal written evaluation of this title.</p>
      <div data-controller="rich-text"
           data-rich-text-name-value="book[readers_report]"
           data-rich-text-value-value="<%= book.readers_report.to_s %>"></div>
    </div>

  </div><%# end tabs container %>

  <%# ══ SAVE (bottom) ═════════════════════════════════════════════════════= %>
  <div class="flex items-center gap-3 pt-4">
    <%= f.submit class: "inline-flex items-center px-5 py-2.5 bg-indigo-600 text-white text-sm
                          font-medium rounded-lg hover:bg-indigo-700 transition-colors cursor-pointer" %>
    <%= link_to "Cancel", books_path,
          class: "inline-flex items-center px-4 py-2 bg-white text-gray-700 text-sm
                  font-medium rounded-lg border border-gray-200 hover:bg-gray-50 transition-colors" %>
  </div>
<% end %>
