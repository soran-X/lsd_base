<%# Partial representing the "Book Info" tab panel. %>
<div data-tab-target="panel" data-tab="info" class="px-6 py-6 space-y-6">

  <%# ══ Book Information ══════════════════════════════════════════════════ %>
  <div class="rounded-lg border border-gray-200 overflow-hidden">
    <div class="bg-gray-50 px-4 py-2.5 border-b border-gray-200">
      <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Book Information</p>
    </div>
    <div class="p-4 space-y-4">

      <%# Title row + Private toggle %>
      <div class="flex gap-4 items-end">
        <div class="flex-1">
          <%= f.label :title, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :title, placeholder: "Title",
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                        focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
        </div>

        <%# Private — padlock toggle %>
        <div class="shrink-0 pb-0.5">
          <label class="flex items-center gap-2 cursor-pointer select-none">
            <%= f.check_box :confidential, class: "sr-only peer" %>
            <%# Toggle track (thumb via after: pseudo-element) %>
            <div class="relative w-11 h-6 rounded-full transition-colors bg-gray-200
                        peer-checked:bg-amber-500
                        after:content-[''] after:absolute after:top-0.5 after:left-0.5
                        after:h-5 after:w-5 after:bg-white after:rounded-full after:shadow
                        after:transition-transform peer-checked:after:translate-x-5"></div>
            <%# Unlocked padlock — visible when not private %>
            <svg class="w-4 h-4 text-gray-400 peer-checked:hidden" xmlns="http://www.w3.org/2000/svg"
                 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                 stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
              <path d="M7 11V7a5 5 0 0 1 9.9-1"/>
            </svg>
            <%# Locked padlock — visible when private %>
            <svg class="w-4 h-4 text-amber-600 hidden peer-checked:block" xmlns="http://www.w3.org/2000/svg"
                 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                 stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
            <span class="text-sm font-medium text-gray-700">Private</span>
          </label>
          <p class="mt-0.5 text-xs text-gray-400 pl-13">Hide from clients</p>
        </div>
      </div>

      <%# Subtitle + Old Title %>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <%= f.label :subtitle, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :subtitle, placeholder: "Subtitle (optional)",
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                        focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
        </div>
        <div>
          <%= f.label :old_title, "Old Title", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :old_title, placeholder: "Previous title (optional)",
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                        focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
        </div>
      </div>

      <%# Authors + Translators side by side %>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <%= render "books/author_combobox",
              label:      "Authors",
              role:       "Author",
              field_name: "book[author_ids][]",
              selected:   book.persisted? ? book.credited_authors.to_a : [] %>
        <%= render "books/author_combobox",
              label:      "Translators",
              role:       "Translator",
              field_name: "book[translator_ids][]",
              selected:   book.persisted? ? book.translators.to_a : [],
              color:      "amber" %>
      </div>

      <%# Genre + Subgenre — side by side %>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

        <%# Genre %>
        <% initial_genres = book.persisted? ? book.genres.ordered.map { |g| { id: g.id, name: g.name } } : [] %>
        <div data-controller="tag-select"
             data-tag-select-selected-value="<%= initial_genres.to_json %>"
             data-tag-select-field-name-value="book[genre_ids][]"
             data-tag-select-color-value="emerald">
          <p class="block text-sm font-medium text-gray-700 mb-2">Genre</p>
          <div data-tag-select-target="tags" class="flex flex-wrap gap-1.5 mb-2 min-h-[2rem]"></div>
          <div data-tag-select-target="inputs"></div>
          <select data-action="change->tag-select#add"
                  data-tag-select-target="select"
                  class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                         focus:outline-none focus:ring-2 focus:ring-indigo-500 bg-white">
            <option value="">Add a genre…</option>
            <% Genre.ordered.each do |g| %>
              <option value="<%= g.id %>"><%= g.name %></option>
            <% end %>
          </select>
        </div>

        <%# Subgenre (independent of genre) %>
        <% initial_subgenres = book.persisted? ? book.sub_genres.ordered.map { |sg| { id: sg.id, name: sg.name } } : [] %>
        <div data-controller="tag-select"
             data-tag-select-selected-value="<%= initial_subgenres.to_json %>"
             data-tag-select-field-name-value="book[sub_genre_ids][]"
             data-tag-select-color-value="amber">
          <p class="block text-sm font-medium text-gray-700 mb-2">Subgenre</p>
          <div data-tag-select-target="tags" class="flex flex-wrap gap-1.5 mb-2 min-h-[2rem]"></div>
          <div data-tag-select-target="inputs"></div>
          <select data-action="change->tag-select#add"
                  data-tag-select-target="select"
                  class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                         focus:outline-none focus:ring-2 focus:ring-indigo-500 bg-white">
            <option value="">Add a subgenre…</option>
            <% SubGenre.ordered.each do |sg| %>
              <option value="<%= sg.id %>"><%= sg.name %></option>
            <% end %>
          </select>
        </div>

      </div>

      <%# Client Type (multiple — tag combobox) %>
      <% initial_client_types = book.persisted? ? book.client_types.ordered.map { |ct| { id: ct.id, name: ct.name } } : [] %>
      <div data-controller="tag-select"
           data-tag-select-selected-value="<%= initial_client_types.to_json %>"
           data-tag-select-field-name-value="book[client_type_ids][]"
           data-tag-select-color-value="rose">
        <p class="block text-sm font-medium text-gray-700 mb-2">Client Type</p>
        <p class="text-xs text-gray-400 mb-2">Clients only see books matching their subscription type.</p>
        <div data-tag-select-target="tags" class="flex flex-wrap gap-1.5 mb-2 min-h-[2rem]"></div>
        <div data-tag-select-target="inputs"></div>
        <select data-action="change->tag-select#add"
                data-tag-select-target="select"
                class="block w-full sm:w-72 rounded-lg border border-gray-300 px-3 py-2 text-sm
                       focus:outline-none focus:ring-2 focus:ring-indigo-500 bg-white">
          <option value="">Add a client type…</option>
          <% ClientType.ordered.each do |ct| %>
            <option value="<%= ct.id %>"><%= ct.name %></option>
          <% end %>
        </select>
      </div>

      <%# Lead Title + Still Tracking toggles %>
      <div class="flex flex-wrap gap-6 pt-1">
        <label class="flex items-center gap-3 cursor-pointer select-none">
          <%= f.check_box :lead_title, class: "sr-only peer" %>
          <div class="relative w-11 h-6 rounded-full transition-colors bg-gray-200
                      peer-checked:bg-indigo-600
                      after:content-[''] after:absolute after:top-0.5 after:left-0.5
                      after:h-5 after:w-5 after:bg-white after:rounded-full after:shadow
                      after:transition-transform peer-checked:after:translate-x-5"></div>
          <span class="text-sm font-medium text-gray-700">Lead Title</span>
        </label>

        <label class="flex items-center gap-3 cursor-pointer select-none">
          <%= f.check_box :tracking_material, class: "sr-only peer" %>
          <div class="relative w-11 h-6 rounded-full transition-colors bg-gray-200
                      peer-checked:bg-indigo-600
                      after:content-[''] after:absolute after:top-0.5 after:left-0.5
                      after:h-5 after:w-5 after:bg-white after:rounded-full after:shadow
                      after:transition-transform peer-checked:after:translate-x-5"></div>
          <span class="text-sm font-medium text-gray-700">Still tracking material?</span>
        </label>
      </div>

    </div>
  </div>

  <%# ══ Administrative ════════════════════════════════════════════════════ %>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <%= f.label :status, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :status,
            Book.statuses.keys.map { |s| [s.humanize, s] },
            { selected: book.status || "draft" },
            class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                    focus:outline-none focus:ring-2 focus:ring-indigo-500 bg-white" %>
    </div>
  </div>

  <%# ── Scouts + Schedule ──────────────────────────────────────────────── %>
  <div class="rounded-lg border border-gray-200 overflow-hidden">
    <div class="grid grid-cols-1 lg:grid-cols-2 divide-y lg:divide-y-0 lg:divide-x divide-gray-200">

      <%# Scouts %>
      <div class="p-4">
        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">Scout Assignment</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div>
            <%= f.label :primary_scout_id, "Primary",
                  class: "block text-xs font-medium text-gray-600 mb-1" %>
            <%= f.select :primary_scout_id,
                  User.order(:last_name, :first_name).map { |u| [u.display_name, u.id] },
                  { include_blank: "— none —", selected: book.primary_scout_id },
                  class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                          focus:outline-none focus:ring-2 focus:ring-indigo-500 bg-white" %>
          </div>
          <div>
            <%= f.label :secondary_scout_id, "Secondary",
                  class: "block text-xs font-medium text-gray-600 mb-1" %>
            <%= f.select :secondary_scout_id,
                  User.order(:last_name, :first_name).map { |u| [u.display_name, u.id] },
                  { include_blank: "— none —", selected: book.secondary_scout_id },
                  class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                          focus:outline-none focus:ring-2 focus:ring-indigo-500 bg-white" %>
          </div>
        </div>
      </div>

      <%# Schedule %>
      <div class="p-4">
        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">Schedule</p>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <%= f.label :delivery_date, "Delivery",
                  class: "block text-xs font-medium text-gray-600 mb-1" %>
            <%= f.date_field :delivery_date,
                  class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                          focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
          </div>
          <div>
            <%= f.label :followup_date, "Follow-up",
                  class: "block text-xs font-medium text-gray-600 mb-1" %>
            <%= f.date_field :followup_date,
                  class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                          focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
          </div>
          <div>
            <%= f.label :publication_season, "Season",
                  class: "block text-xs font-medium text-gray-600 mb-1" %>
            <%= f.select :publication_season,
                  [["— none —", ""]] + Book::SEASONS,
                  { selected: book.publication_season },
                  class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                          focus:outline-none focus:ring-2 focus:ring-indigo-500 bg-white" %>
          </div>
          <div>
            <%= f.label :publication_year, "Year",
                  class: "block text-xs font-medium text-gray-600 mb-1" %>
            <%= f.select :publication_year,
                  [["— none —", ""]] + Book::PUBLICATION_YEARS.map { |y| [y.to_s, y] },
                  { selected: book.publication_year },
                  class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                          focus:outline-none focus:ring-2 focus:ring-indigo-500 bg-white" %>
          </div>
        </div>
      </div>

    </div>
  </div>

  <%# ══ Associated Companies & Contacts ════════════════════════════════ %>
  <div class="rounded-lg border border-gray-200">
    <div class="bg-gray-50 px-4 py-2.5 border-b border-gray-200 rounded-t-lg">
      <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Associated Companies & Contacts</p>
    </div>
    <div class="p-4 space-y-5">

      <%# Row 1: Publisher + Editor %>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

        <%# Publisher — single company (Publisher type) %>
        <div>
          <p class="block text-xs font-medium text-gray-600 mb-1">Publisher</p>
          <% publisher_bc = book.persisted? ? book.book_companies.find_by(role: BookCompany.roles[:publisher]) : nil %>
          <div class="relative"
               data-controller="company-combobox"
               data-company-combobox-url-value="<%= search_companies_path(format: :json, type: 'Publisher') %>">
            <input type="text"
                   data-company-combobox-target="input"
                   placeholder="Search publishers…"
                   value="<%= publisher_bc&.company&.name %>"
                   autocomplete="off"
                   class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                           focus:outline-none focus:ring-2 focus:ring-indigo-500"
                   data-action="input->company-combobox#search keydown->company-combobox#onKeydown" />
            <input type="hidden"
                   name="book[publisher_company_id]"
                   value="<%= publisher_bc&.company_id %>"
                   data-company-combobox-target="hiddenField" />
            <div data-company-combobox-target="dropdown"
                 class="hidden absolute z-50 left-0 right-0 mt-1 bg-white rounded-lg border
                        border-gray-200 shadow-lg overflow-hidden max-h-52 overflow-y-auto"></div>
          </div>
        </div>

        <%# Editor — single company (any type) %>
        <div>
          <p class="block text-xs font-medium text-gray-600 mb-1">Editor</p>
          <% editor_bc = book.persisted? ? book.book_companies.find_by(role: BookCompany.roles[:editor]) : nil %>
          <div class="relative"
               data-controller="company-combobox"
               data-company-combobox-url-value="<%= search_companies_path(format: :json) %>">
            <input type="text"
                   data-company-combobox-target="input"
                   placeholder="Search companies…"
                   value="<%= editor_bc&.company&.name %>"
                   autocomplete="off"
                   class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                           focus:outline-none focus:ring-2 focus:ring-indigo-500"
                   data-action="input->company-combobox#search keydown->company-combobox#onKeydown" />
            <input type="hidden"
                   name="book[editor_company_id]"
                   value="<%= editor_bc&.company_id %>"
                   data-company-combobox-target="hiddenField" />
            <div data-company-combobox-target="dropdown"
                 class="hidden absolute z-50 left-0 right-0 mt-1 bg-white rounded-lg border
                        border-gray-200 shadow-lg overflow-hidden max-h-52 overflow-y-auto"></div>
          </div>
        </div>

      </div>

      <%# Row 2: Agent(s) + Agency(ies) %>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

        <%# Agent(s) — multi contact %>
        <% agent_contacts = book.persisted? ? book.book_contacts.where(role: BookContact.roles[:agent]).includes(:contact).map { |bc| { id: bc.contact_id, label: bc.contact.display_name } } : [] %>
        <div data-controller="contact-chips"
             data-contact-chips-search-url-value="<%= search_contacts_path(format: :json) %>"
             data-contact-chips-field-name-value="book[agent_contact_ids][]">
          <p class="block text-xs font-medium text-gray-600 mb-1">Agent(s)</p>
          <div data-contact-chips-target="chips" class="flex flex-wrap gap-1.5 mb-2 min-h-[2rem]">
            <% agent_contacts.each do |c| %>
              <div class="inline-flex items-center gap-2 pl-3 pr-2 py-1.5 rounded-full text-sm font-medium
                          bg-violet-50 text-violet-800 border border-violet-200"
                   data-contact-id="<%= c[:id] %>" data-contact-label="<%= c[:label] %>">
                <span><%= c[:label] %></span>
                <input type="hidden" name="book[agent_contact_ids][]" value="<%= c[:id] %>">
                <button type="button" data-contact-id="<%= c[:id] %>"
                        data-action="click->contact-chips#removeChip"
                        class="rounded-full p-0.5 hover:bg-violet-200 text-violet-400 hover:text-violet-700 transition-colors">
                  <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-2.72 2.72a.75.75 0 101.06 1.06L10 11.06l2.72 2.72a.75.75 0 101.06-1.06L11.06 10l2.72-2.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z"/>
                  </svg>
                </button>
              </div>
            <% end %>
          </div>
          <div class="relative">
            <input type="text"
                   data-contact-chips-target="input"
                   placeholder="Search contacts…"
                   autocomplete="off"
                   class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                           focus:outline-none focus:ring-2 focus:ring-indigo-500"
                   data-action="input->contact-chips#onInput keydown->contact-chips#onKeydown" />
            <div data-contact-chips-target="dropdown"
                 class="hidden absolute z-50 left-0 right-0 mt-1 bg-white rounded-lg border
                        border-gray-200 shadow-lg overflow-hidden max-h-52 overflow-y-auto">
              <ul data-contact-chips-target="list" role="listbox"></ul>
            </div>
          </div>
        </div>

        <%# Agency(ies) — multi company %>
        <% agency_companies = book.persisted? ? book.book_companies.where(role: BookCompany.roles[:agency]).includes(:company).map { |bc| { id: bc.company_id, label: bc.company.name } } : [] %>
        <div data-controller="company-chips"
             data-company-chips-search-url-value="<%= search_companies_path(format: :json) %>"
             data-company-chips-field-name-value="book[agency_company_ids][]">
          <p class="block text-xs font-medium text-gray-600 mb-1">Agency(ies)</p>
          <div data-company-chips-target="chips" class="flex flex-wrap gap-1.5 mb-2 min-h-[2rem]">
            <% agency_companies.each do |c| %>
              <div class="inline-flex items-center gap-2 pl-3 pr-2 py-1.5 rounded-full text-sm font-medium
                          bg-sky-50 text-sky-800 border border-sky-200"
                   data-company-id="<%= c[:id] %>" data-company-label="<%= c[:label] %>">
                <span><%= c[:label] %></span>
                <input type="hidden" name="book[agency_company_ids][]" value="<%= c[:id] %>">
                <button type="button" data-company-id="<%= c[:id] %>"
                        data-action="click->company-chips#removeChip"
                        class="rounded-full p-0.5 hover:bg-sky-200 text-sky-400 hover:text-sky-700 transition-colors">
                  <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-2.72 2.72a.75.75 0 101.06 1.06L10 11.06l2.72 2.72a.75.75 0 101.06-1.06L11.06 10l2.72-2.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z"/>
                  </svg>
                </button>
              </div>
            <% end %>
          </div>
          <div class="relative">
            <input type="text"
                   data-company-chips-target="input"
                   placeholder="Search companies…"
                   autocomplete="off"
                   class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                           focus:outline-none focus:ring-2 focus:ring-indigo-500"
                   data-action="input->company-chips#onInput keydown->company-chips#onKeydown" />
            <div data-company-chips-target="dropdown"
                 class="hidden absolute z-50 left-0 right-0 mt-1 bg-white rounded-lg border
                        border-gray-200 shadow-lg overflow-hidden max-h-52 overflow-y-auto">
              <ul data-company-chips-target="list" role="listbox"></ul>
            </div>
          </div>
        </div>

      </div>

      <%# Row 3: Film Agent(s) + Film Agency(ies) %>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

        <%# Film Agent(s) — multi contact %>
        <% film_agent_contacts = book.persisted? ? book.book_contacts.where(role: BookContact.roles[:film_agent]).includes(:contact).map { |bc| { id: bc.contact_id, label: bc.contact.display_name } } : [] %>
        <div data-controller="contact-chips"
             data-contact-chips-search-url-value="<%= search_contacts_path(format: :json) %>"
             data-contact-chips-field-name-value="book[film_agent_contact_ids][]">
          <p class="block text-xs font-medium text-gray-600 mb-1">Film Agent(s)</p>
          <div data-contact-chips-target="chips" class="flex flex-wrap gap-1.5 mb-2 min-h-[2rem]">
            <% film_agent_contacts.each do |c| %>
              <div class="inline-flex items-center gap-2 pl-3 pr-2 py-1.5 rounded-full text-sm font-medium
                          bg-violet-50 text-violet-800 border border-violet-200"
                   data-contact-id="<%= c[:id] %>" data-contact-label="<%= c[:label] %>">
                <span><%= c[:label] %></span>
                <input type="hidden" name="book[film_agent_contact_ids][]" value="<%= c[:id] %>">
                <button type="button" data-contact-id="<%= c[:id] %>"
                        data-action="click->contact-chips#removeChip"
                        class="rounded-full p-0.5 hover:bg-violet-200 text-violet-400 hover:text-violet-700 transition-colors">
                  <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-2.72 2.72a.75.75 0 101.06 1.06L10 11.06l2.72 2.72a.75.75 0 101.06-1.06L11.06 10l2.72-2.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z"/>
                  </svg>
                </button>
              </div>
            <% end %>
          </div>
          <div class="relative">
            <input type="text"
                   data-contact-chips-target="input"
                   placeholder="Search contacts…"
                   autocomplete="off"
                   class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                           focus:outline-none focus:ring-2 focus:ring-indigo-500"
                   data-action="input->contact-chips#onInput keydown->contact-chips#onKeydown" />
            <div data-contact-chips-target="dropdown"
                 class="hidden absolute z-50 left-0 right-0 mt-1 bg-white rounded-lg border
                        border-gray-200 shadow-lg overflow-hidden max-h-52 overflow-y-auto">
              <ul data-contact-chips-target="list" role="listbox"></ul>
            </div>
          </div>
        </div>

        <%# Film Agency(ies) — multi company %>
        <% film_agency_companies = book.persisted? ? book.book_companies.where(role: BookCompany.roles[:film_agency]).includes(:company).map { |bc| { id: bc.company_id, label: bc.company.name } } : [] %>
        <div data-controller="company-chips"
             data-company-chips-search-url-value="<%= search_companies_path(format: :json) %>"
             data-company-chips-field-name-value="book[film_agency_company_ids][]">
          <p class="block text-xs font-medium text-gray-600 mb-1">Film Agency(ies)</p>
          <div data-company-chips-target="chips" class="flex flex-wrap gap-1.5 mb-2 min-h-[2rem]">
            <% film_agency_companies.each do |c| %>
              <div class="inline-flex items-center gap-2 pl-3 pr-2 py-1.5 rounded-full text-sm font-medium
                          bg-sky-50 text-sky-800 border border-sky-200"
                   data-company-id="<%= c[:id] %>" data-company-label="<%= c[:label] %>">
                <span><%= c[:label] %></span>
                <input type="hidden" name="book[film_agency_company_ids][]" value="<%= c[:id] %>">
                <button type="button" data-company-id="<%= c[:id] %>"
                        data-action="click->company-chips#removeChip"
                        class="rounded-full p-0.5 hover:bg-sky-200 text-sky-400 hover:text-sky-700 transition-colors">
                  <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-2.72 2.72a.75.75 0 101.06 1.06L10 11.06l2.72 2.72a.75.75 0 101.06-1.06L11.06 10l2.72-2.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z"/>
                  </svg>
                </button>
              </div>
            <% end %>
          </div>
          <div class="relative">
            <input type="text"
                   data-company-chips-target="input"
                   placeholder="Search companies…"
                   autocomplete="off"
                   class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                           focus:outline-none focus:ring-2 focus:ring-indigo-500"
                   data-action="input->company-chips#onInput keydown->company-chips#onKeydown" />
            <div data-company-chips-target="dropdown"
                 class="hidden absolute z-50 left-0 right-0 mt-1 bg-white rounded-lg border
                        border-gray-200 shadow-lg overflow-hidden max-h-52 overflow-y-auto">
              <ul data-company-chips-target="list" role="listbox"></ul>
            </div>
          </div>
        </div>

      </div>

    </div>
  </div>

  <%# Synopsis %>
  <div>
    <%= f.label :synopsis, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <div data-controller="rich-text"
         data-rich-text-name-value="book[synopsis]"
         data-rich-text-value-value="<%= book.synopsis.to_s %>"></div>
  </div>

</div>
