<%# Film tracking tab panel. %>
<div data-tab-target="panel" data-tab="film" class="hidden px-6 py-6 space-y-6">

  <%= f.fields_for :film_tracking do |ft| %>

    <%# ── Film Option (+ Film Activity) ─────────────────────────────────── %>
    <div class="field-group" data-controller="nested-form">
      <div class="field-group-header">
        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Film Option</p>
      </div>
      <div class="p-4 space-y-4">
        <div>
          <%= ft.label :film_option_date, "Date Created",
                class: "block text-xs font-medium text-gray-600 mb-1" %>
          <%= ft.date_field :film_option_date,
                class: "block rounded-lg border border-gray-300 px-3 py-2 text-sm
                        focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
        </div>
        <div>
          <%= ft.label :film_option, "Film Option",
                class: "block text-sm font-medium text-gray-700 mb-1" %>
          <div data-controller="rich-text"
               data-rich-text-name-value="<%= ft.object_name %>[film_option]"
               data-rich-text-value-value="<%= ft.object.film_option.to_s %>"></div>
        </div>
      </div>

      <%# Film Activity rows %>
      <div class="border-t border-gray-200">
        <div class="bg-gray-50 px-4 py-2 border-b border-gray-100">
          <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Film Activity</p>
        </div>
        <div class="divide-y divide-gray-100" data-nested-form-target="container">
          <%= f.fields_for :film_activities do |fa| %>
            <div class="p-4" data-nested-form-row>
              <%= fa.hidden_field :id %>
              <%= fa.hidden_field :_destroy, value: "0" %>
              <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 items-end">
                <div>
                  <%= fa.label :date, class: "block text-xs font-medium text-gray-600 mb-1" %>
                  <%= fa.date_field :date,
                        class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                                focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
                </div>
                <div class="relative"
                     data-controller="company-combobox"
                     data-company-combobox-url-value="<%= search_companies_path(format: :json) %>">
                  <p class="block text-xs font-medium text-gray-600 mb-1">Client</p>
                  <input type="text"
                         data-company-combobox-target="input"
                         placeholder="Search companies…"
                         value="<%= fa.object.company&.name %>"
                         autocomplete="off"
                         class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                                 focus:outline-none focus:ring-2 focus:ring-indigo-500"
                         data-action="input->company-combobox#search keydown->company-combobox#onKeydown" />
                  <input type="hidden"
                         name="<%= fa.object_name %>[company_id]"
                         value="<%= fa.object.company_id %>"
                         data-company-combobox-target="hiddenField" />
                  <div data-company-combobox-target="dropdown"
                       class="combo-dropdown hidden max-h-52 overflow-y-auto"></div>
                </div>
                <div class="flex gap-2 items-end">
                  <div class="flex-1">
                    <%= fa.label :notes, class: "block text-xs font-medium text-gray-600 mb-1" %>
                    <%= fa.text_field :notes, placeholder: "Notes",
                          class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                                  focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
                  </div>
                  <button type="button" data-action="nested-form#remove"
                          class="shrink-0 text-xs text-red-400 hover:text-red-600 pb-2.5 transition-colors">Remove</button>
                </div>
              </div>
            </div>
          <% end %>
        </div>

        <template data-nested-form-target="template">
          <%= f.fields_for :film_activities, FilmActivity.new, child_index: "__INDEX__" do |fa| %>
            <div class="p-4" data-nested-form-row>
              <%= fa.hidden_field :id %>
              <%= fa.hidden_field :_destroy, value: "0" %>
              <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 items-end">
                <div>
                  <%= fa.label :date, class: "block text-xs font-medium text-gray-600 mb-1" %>
                  <%= fa.date_field :date,
                        class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                                focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
                </div>
                <div class="relative"
                     data-controller="company-combobox"
                     data-company-combobox-url-value="<%= search_companies_path(format: :json) %>">
                  <p class="block text-xs font-medium text-gray-600 mb-1">Client</p>
                  <input type="text"
                         data-company-combobox-target="input"
                         placeholder="Search companies…"
                         value=""
                         autocomplete="off"
                         class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                                 focus:outline-none focus:ring-2 focus:ring-indigo-500"
                         data-action="input->company-combobox#search keydown->company-combobox#onKeydown" />
                  <input type="hidden"
                         name="<%= fa.object_name %>[company_id]"
                         value=""
                         data-company-combobox-target="hiddenField" />
                  <div data-company-combobox-target="dropdown"
                       class="combo-dropdown hidden max-h-52 overflow-y-auto"></div>
                </div>
                <div class="flex gap-2 items-end">
                  <div class="flex-1">
                    <%= fa.label :notes, class: "block text-xs font-medium text-gray-600 mb-1" %>
                    <%= fa.text_field :notes, placeholder: "Notes",
                          class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                                  focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
                  </div>
                  <button type="button" data-action="nested-form#remove"
                          class="shrink-0 text-xs text-red-400 hover:text-red-600 pb-2.5 transition-colors">Remove</button>
                </div>
              </div>
            </div>
          <% end %>
        </template>

        <div class="px-4 py-3 bg-gray-50 border-t border-gray-100">
          <button type="button" data-action="nested-form#add"
                  class="text-xs font-medium text-indigo-600 hover:text-indigo-800 transition-colors">
            + Add Film Activity
          </button>
        </div>
      </div>
    </div>

    <%# ── Film Info ──────────────────────────────────────────────────────── %>
    <div class="rounded-lg border border-gray-200" data-controller="film-load-book-info">

      <div class="field-group-header flex items-center justify-between">
        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Film Info</p>
        <div class="flex items-center gap-4">
          <%# Load from Book Info button %>
          <button type="button"
                  data-action="click->film-load-book-info#open"
                  class="inline-flex items-center gap-1.5 px-3 py-1 bg-indigo-50 text-indigo-700
                         text-xs font-medium rounded-md border border-indigo-200
                         hover:bg-indigo-100 transition-colors cursor-pointer">
            <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M4 2a1 1 0 011 1v2.101a7.002 7.002 0 0111.601 2.566 1 1 0 11-1.885.666A5.002 5.002 0 005.999 7H9a1 1 0 010 2H4a1 1 0 01-1-1V3a1 1 0 011-1zm.008 9.057a1 1 0 011.276.61A5.002 5.002 0 0014.001 13H11a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0v-2.101a7.002 7.002 0 01-11.601-2.566 1 1 0 01.61-1.276z" clip-rule="evenodd"/>
            </svg>
            Load from Book Info
          </button>
          <%# OFF / Pub Buzz select %>
          <%= ft.select :film_flag,
                [["—", ""], ["Out for Film", "Out for Film"], ["Pub Buzz", "Pub Buzz"]],
                { selected: ft.object.film_flag.to_s },
                class: "text-xs rounded-md border border-gray-200 bg-white px-2 py-1
                        text-gray-700 focus:outline-none focus:ring-2 focus:ring-indigo-500
                        cursor-pointer" %>
        </div>
      </div>

      <div class="p-4 space-y-5">

        <%# Comments %>
        <div data-film-target="comments" data-film-load-book-info-target="commentsContainer">
          <p class="block text-sm font-medium text-gray-700 mb-1">Comments</p>
          <div data-controller="rich-text"
               data-rich-text-name-value="<%= ft.object_name %>[comments]"
               data-rich-text-value-value="<%= ft.object.comments.to_s %>"></div>
        </div>

        <%# Synopsis (film-specific) %>
        <div data-film-target="synopsis" data-film-load-book-info-target="synopsisContainer">
          <p class="block text-sm font-medium text-gray-700 mb-1">Synopsis</p>
          <div data-controller="rich-text"
               data-rich-text-name-value="<%= ft.object_name %>[film_synopsis]"
               data-rich-text-value-value="<%= ft.object.film_synopsis.to_s %>"></div>
        </div>

        <%# Material %>
        <div data-film-target="material" data-film-load-book-info-target="materialContainer">
          <p class="block text-sm font-medium text-gray-700 mb-1">Material</p>
          <div data-controller="rich-text"
               data-rich-text-name-value="<%= ft.object_name %>[material]"
               data-rich-text-value-value="<%= ft.object.material.to_s %>"></div>
        </div>

        <%# Reader's Thoughts %>
        <div>
          <p class="block text-sm font-medium text-gray-700 mb-1">Reader's Thoughts</p>
          <div data-controller="rich-text"
               data-rich-text-name-value="<%= ft.object_name %>[readers_thoughts]"
               data-rich-text-value-value="<%= ft.object.readers_thoughts.to_s %>"></div>
        </div>

        <%# Enable Red Text toggle %>
        <div data-controller="toggle" data-toggle-show-value="<%= ft.object.enable_red_text? %>">
          <label class="flex items-center gap-2 cursor-pointer select-none">
            <%= ft.check_box :enable_red_text, class: "sr-only peer",
                  data: { action: "change->toggle#toggle" } %>
            <div class="relative w-9 h-5 rounded-full transition-colors bg-gray-200
                        peer-checked:bg-red-600
                        after:content-[''] after:absolute after:top-0.5 after:left-0.5
                        after:h-4 after:w-4 after:bg-white after:rounded-full after:shadow
                        after:transition-transform peer-checked:after:translate-x-4"></div>
            <span class="text-sm font-medium text-gray-700">Enable Red Text</span>
          </label>
          <div data-toggle-target="content" class="mt-3<%= ft.object.enable_red_text? ? '' : ' hidden' %>">
            <p class="block text-sm font-medium text-gray-700 mb-1">Red Text</p>
            <%= ft.text_area :red_text, rows: 3,
                  class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                          focus:outline-none focus:ring-2 focus:ring-red-400 resize-y" %>
          </div>
        </div>

        <%# Film Genre — multi-select with create %>
        <% film_genre_ids = ft.object.persisted? ? ft.object.film_genres.map { |g| { id: g.id, label: g.name } } : [] %>
        <div data-controller="film-genre-chips"
             data-film-genre-chips-search-url-value="<%= search_film_genres_path(format: :json) %>"
             data-film-genre-chips-create-url-value="<%= film_genres_path(format: :json) %>"
             data-film-genre-chips-field-name-value="book[film_genre_ids][]">
          <p class="block text-sm font-medium text-gray-700 mb-2">Film Genre</p>
          <div data-film-genre-chips-target="chips" class="flex flex-wrap gap-1.5 mb-2 min-h-[2rem]">
            <% film_genre_ids.each do |g| %>
              <div class="inline-flex items-center gap-2 pl-3 pr-2 py-1.5 rounded-full text-sm font-medium
                          bg-purple-50 text-purple-800 border border-purple-200"
                   data-genre-id="<%= g[:id] %>" data-genre-label="<%= g[:label] %>">
                <span><%= g[:label] %></span>
                <input type="hidden" name="book[film_genre_ids][]" value="<%= g[:id] %>">
                <button type="button" data-genre-id="<%= g[:id] %>"
                        data-action="click->film-genre-chips#removeChip"
                        class="rounded-full p-0.5 hover:bg-purple-200 text-purple-400 hover:text-purple-700 transition-colors">
                  <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-2.72 2.72a.75.75 0 101.06 1.06L10 11.06l2.72 2.72a.75.75 0 101.06-1.06L11.06 10l2.72-2.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z"/>
                  </svg>
                </button>
              </div>
            <% end %>
          </div>
          <div class="relative">
            <input type="text"
                   data-film-genre-chips-target="input"
                   placeholder="Search or create film genres..."
                   autocomplete="off"
                   class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                           focus:outline-none focus:ring-2 focus:ring-indigo-500"
                   data-action="input->film-genre-chips#onInput keydown->film-genre-chips#onKeydown" />
            <div data-film-genre-chips-target="dropdown"
                 class="combo-dropdown hidden max-h-52 overflow-y-auto"
              <ul data-film-genre-chips-target="list" role="listbox"></ul>
            </div>
          </div>
        </div>

      </div>

      <%# ── Confirmation dialog ────────────────────────────────────────────── %>
      <dialog data-film-load-book-info-target="dialog"
              class="confirm-dialog rounded-2xl shadow-2xl border-0 p-0 w-full max-w-sm">
        <div class="p-6">
          <div class="flex items-start gap-4 mb-5">
            <div class="shrink-0 w-10 h-10 rounded-full bg-indigo-100 flex items-center justify-center">
              <svg class="w-5 h-5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
              </svg>
            </div>
            <div class="flex-1 min-w-0 pt-0.5">
              <h3 class="text-base font-semibold text-gray-900 mb-1">Load from Book Info?</h3>
              <p class="text-sm text-gray-500 leading-relaxed">
                This will overwrite <strong class="font-medium text-gray-700">Comments</strong>,
                <strong class="font-medium text-gray-700">Synopsis</strong>, and
                <strong class="font-medium text-gray-700">Material</strong> in Film Info
                with content from Book Info. This cannot be undone.
              </p>
            </div>
          </div>
          <div class="flex justify-end gap-2">
            <button data-action="click->film-load-book-info#cancel" type="button"
                    class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-200
                           rounded-lg hover:bg-gray-50 transition-colors">
              Cancel
            </button>
            <button data-action="click->film-load-book-info#confirm" type="button"
                    class="px-4 py-2 text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700
                           rounded-lg transition-colors">
              Yes, Load
            </button>
          </div>
        </div>
      </dialog>
    </div>

  <% end %>

</div>
