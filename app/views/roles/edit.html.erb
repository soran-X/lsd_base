<% content_for :title, "Edit #{@role.name} — ClinicDev" %>

<div class="mb-6">
  <div class="flex items-center gap-2 text-sm text-gray-500 mb-2">
    <%= link_to "Roles", roles_path, class: "hover:text-gray-700" %>
    <span>/</span>
    <span class="text-gray-900">Edit</span>
  </div>
  <h1 class="text-2xl font-bold text-gray-900">Edit Role</h1>
  <p class="mt-1 text-sm text-gray-500"><%= @role.name %></p>
</div>

<%= form_with model: @role do |f| %>
  <%= f.hidden_field :permission_ids, value: "" %>

  <div class="space-y-6">

    <%# ── Role Details ──────────────────────────────────── %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
      <h2 class="text-sm font-semibold text-gray-700 mb-4">Role Details</h2>

      <% if @role.errors.any? %>
        <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-4">
          <h3 class="text-sm font-semibold text-red-800 mb-1"><%= pluralize(@role.errors.count, "error") %> prevented saving:</h3>
          <ul class="list-disc list-inside space-y-1">
            <% @role.errors.each do |error| %>
              <li class="text-sm text-red-700"><%= error.full_message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-xl">
        <div>
          <%= f.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :name,
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent",
                placeholder: "e.g. Manager" %>
        </div>
        <div>
          <%= f.label :hierarchy_level, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.number_field :hierarchy_level,
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent",
                placeholder: "1–100", min: 1, max: 100 %>
          <p class="text-xs text-gray-400 mt-1">Max you can set: <%= Current.user.hierarchy_level %>.</p>
        </div>
      </div>
    </div>

    <%# ── Permissions Matrix ─────────────────────────────── %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100">
      <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
        <div>
          <h2 class="text-sm font-semibold text-gray-700">Permissions</h2>
          <p class="text-xs text-gray-400 mt-0.5">Check each action this role is allowed to perform.</p>
        </div>
        <span class="text-xs font-medium text-indigo-600 bg-indigo-50 px-2 py-0.5 rounded-full"><%= @granted_ids.size %> granted</span>
      </div>

      <div class="overflow-x-auto">
        <table class="min-w-full">
          <thead>
            <tr class="bg-gray-50 border-b border-gray-100">
              <th class="text-left px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider sticky left-0 bg-gray-50 min-w-[130px]">Resource</th>
              <% action_labels = { "new" => "new / create", "edit" => "edit / update" } %>
              <% @all_actions.each do |action| %>
                <th class="px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider text-center min-w-[100px]">
                  <%= action_labels.fetch(action, action) %>
                </th>
              <% end %>
            </tr>
          </thead>
          <tbody>
            <% @all_resources.each_with_index do |resource, i| %>
              <tr class="<%= i.even? ? 'bg-white' : 'bg-gray-50/50' %> hover:bg-indigo-50/30 transition-colors border-b border-gray-100 last:border-0">
                <td class="px-6 py-4 text-sm font-medium text-gray-800 capitalize sticky left-0 <%= i.even? ? 'bg-white' : 'bg-gray-50/50' %> hover:bg-indigo-50/30">
                  <%= resource.tr("_", " ") %>
                </td>
                <% @all_actions.each do |action| %>
                  <td class="px-4 py-4 text-center">
                    <% perm = @permission_map["#{resource}:#{action}"] %>
                    <% if perm %>
                      <%= check_box_tag "role[permission_ids][]",
                                        perm.id,
                                        @granted_ids.include?(perm.id),
                                        id: "perm_#{perm.id}",
                                        class: "w-4 h-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500 cursor-pointer" %>
                    <% else %>
                      <span class="block w-4 h-px bg-gray-200 mx-auto"></span>
                    <% end %>
                  </td>
                <% end %>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <%# ── Save ──────────────────────────────────────────── %>
    <div class="flex items-center gap-3 pb-2">
      <%= f.submit "Save Changes",
            class: "px-6 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition-colors cursor-pointer" %>
      <%= link_to "Cancel", roles_path,
            class: "px-4 py-2 bg-white text-gray-700 text-sm font-medium rounded-lg border border-gray-200 hover:bg-gray-50 transition-colors" %>
      <%= link_to "View Role", role_path(@role),
            class: "ml-auto text-sm text-gray-500 hover:text-gray-700" %>
    </div>

  </div>
<% end %>
