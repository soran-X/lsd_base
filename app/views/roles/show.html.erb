<% content_for :title, "#{@role.name} — ClinicDev" %>

<div class="mb-6">
  <div class="flex items-center gap-2 text-sm text-gray-500 mb-2">
    <%= link_to "Roles", roles_path, class: "hover:text-gray-700" %>
    <span>/</span>
    <span class="text-gray-900"><%= @role.name %></span>
  </div>
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-gray-900"><%= @role.name %></h1>
    <%= link_to "Edit Permissions", edit_role_path(@role), class: "inline-flex items-center px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition-colors" %>
  </div>
</div>

<div class="space-y-6 max-w-2xl">
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 divide-y divide-gray-100">
    <div class="px-6 py-4 flex justify-between text-sm">
      <span class="font-medium text-gray-500">Name</span>
      <span class="text-gray-900"><%= @role.name %></span>
    </div>
    <div class="px-6 py-4 flex justify-between text-sm">
      <span class="font-medium text-gray-500">Hierarchy Level</span>
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-50 text-indigo-700"><%= @role.hierarchy_level %></span>
    </div>
    <div class="px-6 py-4 flex justify-between text-sm">
      <span class="font-medium text-gray-500">Assigned Users</span>
      <span class="text-gray-900"><%= @role.users.count %></span>
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-100">
      <h2 class="text-sm font-semibold text-gray-700">Permissions</h2>
    </div>
    <% grouped = @role.permissions.group_by(&:resource).sort %>
    <% if grouped.empty? %>
      <p class="px-6 py-4 text-sm text-gray-400">No permissions assigned.</p>
    <% else %>
      <div class="divide-y divide-gray-100">
        <% grouped.each do |resource, permissions| %>
          <div class="px-6 py-3">
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2"><%= resource %></p>
            <div class="flex flex-wrap gap-2">
              <% permissions.each do |perm| %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-50 text-indigo-700">
                  <%= perm.action %>
                </span>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
