<dl class="grid grid-cols-1 gap-4 sm:grid-cols-2">
  <div class="sm:col-span-1">
    <dt class="text-sm font-medium text-gray-500">Name</dt>
    <dd class="mt-1 text-sm text-gray-900 font-semibold"><%= author.name %></dd>
  </div>

  <div class="sm:col-span-2">
    <dt class="text-sm font-medium text-gray-500">Bio</dt>
    <dd class="mt-1 text-sm text-gray-900 leading-relaxed whitespace-pre-wrap">
      <%= author.bio.presence || %(<span class="text-gray-400 italic">No bio provided.</span>).html_safe %>
    </dd>
  </div>
</dl>
