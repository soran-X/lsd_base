<div class="flex items-center justify-between mb-6 gap-4 flex-wrap">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Authors</h1>
    <p class="text-sm text-gray-500 mt-0.5"><%= @authors.size %> <%= "author".pluralize(@authors.size) %></p>
  </div>
  <div class="flex items-center gap-3">
    <%= form_with url: authors_path, method: :get, class: "flex items-center gap-2" do |f| %>
      <%= f.text_field :q, value: @query, placeholder: "Search authors…",
            class: "block rounded-lg border border-gray-300 px-3 py-2 text-sm w-56
                    focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
      <% if @query.present? %>
        <%= link_to "Clear", authors_path, class: "text-xs text-gray-400 hover:text-gray-600" %>
      <% end %>
    <% end %>
    <%= link_to "New Author", new_author_path,
          class: "inline-flex items-center px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition-colors" %>
  </div>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
  <table class="w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="text-xs font-medium text-gray-500 uppercase tracking-wider px-6 py-3 text-left">Name</th>
        <th class="text-xs font-medium text-gray-500 uppercase tracking-wider px-6 py-3 text-left">Bio</th>
        <th class="text-xs font-medium text-gray-500 uppercase tracking-wider px-6 py-3 text-left">Books</th>
        <th class="text-xs font-medium text-gray-500 uppercase tracking-wider px-6 py-3 text-left">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% @authors.each do |author| %>
        <tr class="bg-white hover:bg-gray-50">
          <td class="px-6 py-4 text-sm text-gray-900 font-medium">
            <%= link_to author.display_name, author_path(author), class: "text-indigo-600 hover:text-indigo-800 hover:underline" %>
          </td>
          <td class="px-6 py-4 text-sm text-gray-900 max-w-xs truncate">
            <%= author.bio.presence || "—" %>
          </td>
          <td class="px-6 py-4 text-sm text-gray-900">
            <%= author.books.count %>
          </td>
          <td class="px-6 py-4 text-sm">
            <div class="flex items-center gap-2">
              <%= link_to "Edit", edit_author_path(author),
                    class: "inline-flex items-center px-4 py-2 bg-white text-gray-700 text-sm font-medium rounded-lg border border-gray-200 hover:bg-gray-50 transition-colors" %>
              <%= button_to "Delete", author_path(author),
                    method: :delete,
                    data: { turbo_confirm: "Are you sure?" },
                    class: "inline-flex items-center px-4 py-2 bg-red-600 text-white text-sm font-medium rounded-lg hover:bg-red-700 transition-colors" %>
            </div>
          </td>
        </tr>
      <% end %>

      <% if @authors.empty? %>
        <tr class="bg-white">
          <td colspan="4" class="px-6 py-10 text-center text-sm text-gray-500">
            <% if @query.present? %>
              No authors match "<%= @query %>". <%= link_to "Clear search", authors_path, class: "text-indigo-600 hover:underline font-medium" %>.
            <% else %>
              No authors found. <%= link_to "Add the first one", new_author_path, class: "text-indigo-600 hover:underline font-medium" %>.
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
