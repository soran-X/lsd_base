<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900"><%= @author.display_name %></h1>
  <div class="flex items-center gap-2">
    <%= link_to "Edit", edit_author_path(@author),
          class: "inline-flex items-center px-4 py-2 bg-white text-gray-700 text-sm font-medium rounded-lg border border-gray-200 hover:bg-gray-50 transition-colors" %>
    <%= link_to "Back to Authors", authors_path,
          class: "inline-flex items-center px-4 py-2 bg-white text-gray-700 text-sm font-medium rounded-lg border border-gray-200 hover:bg-gray-50 transition-colors" %>
  </div>
</div>

<%# Author detail card %>
<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden mb-6">
  <div class="px-6 py-5 border-b border-gray-100">
    <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wider">Author Details</h2>
  </div>
  <div class="px-6 py-5">
    <%= render @author %>
  </div>
  <div class="px-6 py-4 bg-gray-50 border-t border-gray-100 flex justify-end">
    <%= button_to "Delete Author", author_path(@author),
          method: :delete,
          data: { turbo_confirm: "Are you sure? This cannot be undone." },
          class: "inline-flex items-center px-4 py-2 bg-red-600 text-white text-sm font-medium rounded-lg hover:bg-red-700 transition-colors" %>
  </div>
</div>

<%# Books authored %>
<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden mb-4">
  <div class="px-6 py-5 border-b border-gray-100 flex items-center justify-between">
    <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wider">
      Books
      <span class="ml-2 inline-flex items-center justify-center px-2 py-0.5 text-xs font-medium bg-indigo-100 text-indigo-700 rounded-full">
        <%= @author.authored_books.count %>
      </span>
    </h2>
  </div>

  <% if @author.authored_books.any? %>
    <ul class="divide-y divide-gray-100">
      <% @author.authored_books.each do |book| %>
        <li class="px-6 py-4 flex items-center justify-between hover:bg-gray-50 transition-colors">
          <div>
            <p class="text-sm font-medium text-gray-900"><%= book.title %></p>
            <% if book.subtitle.present? %>
              <p class="text-xs text-gray-500 mt-0.5"><%= book.subtitle %></p>
            <% end %>
          </div>
          <%= link_to "View", book_path(book),
                class: "inline-flex items-center px-4 py-2 bg-white text-gray-700 text-sm font-medium rounded-lg border border-gray-200 hover:bg-gray-50 transition-colors" %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <div class="px-6 py-10 text-center text-sm text-gray-500">
      No books authored yet.
    </div>
  <% end %>
</div>

<%# Books translated %>
<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
  <div class="px-6 py-5 border-b border-gray-100 flex items-center justify-between">
    <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wider">
      Translations
      <span class="ml-2 inline-flex items-center justify-center px-2 py-0.5 text-xs font-medium bg-teal-100 text-teal-700 rounded-full">
        <%= @author.translated_books.count %>
      </span>
    </h2>
  </div>

  <% if @author.translated_books.any? %>
    <ul class="divide-y divide-gray-100">
      <% @author.translated_books.each do |book| %>
        <li class="px-6 py-4 flex items-center justify-between hover:bg-gray-50 transition-colors">
          <p class="text-sm font-medium text-gray-900"><%= book.title %></p>
          <%= link_to "View", book_path(book),
                class: "inline-flex items-center px-4 py-2 bg-white text-gray-700 text-sm font-medium rounded-lg border border-gray-200 hover:bg-gray-50 transition-colors" %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <div class="px-6 py-10 text-center text-sm text-gray-500">
      No translations on record.
    </div>
  <% end %>
</div>
