<%= form_with model: template, class: "space-y-6" do |f| %>
  <%= render "custom_report_templates/form_errors", template: template %>

  <%# Name %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
    <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-4">Template Name</h2>
    <%= f.label :name, "Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :name,
          class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                  focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent",
          placeholder: "e.g. Film Summary, Rights Report…" %>
  </div>

  <%# Fields selection %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
    <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-4">Fields to Include</h2>
    <p class="text-xs text-gray-400 mb-4">Select which book fields appear in reports using this template. Order is preserved.</p>

    <% current_keys = template.persisted? ? template.field_keys : [] %>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <% CustomReportTemplate.field_groups.each do |group_name, group_keys| %>
        <div>
          <p class="text-xs font-semibold text-gray-700 uppercase tracking-wider mb-2"><%= group_name %></p>
          <div class="space-y-1.5">
            <% group_keys.each do |key| %>
              <label class="flex items-center gap-2 cursor-pointer hover:bg-gray-50 rounded px-2 py-1 transition-colors">
                <input type="checkbox"
                       name="custom_report_template[field_keys][]"
                       value="<%= key %>"
                       <%= "checked" if current_keys.include?(key) %>
                       class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
                <span class="text-sm text-gray-700"><%= InstanceConfig.label(key) %></span>
              </label>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <%# Sections %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6"
       data-controller="nested-form">
    <div class="flex items-center justify-between mb-4">
      <div>
        <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wider">Sections (Optional)</h2>
        <p class="text-xs text-gray-400 mt-0.5">Books will be grouped under these sections in the report</p>
      </div>
      <button type="button"
              data-action="nested-form#add"
              class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-indigo-600
                     border border-indigo-200 rounded-lg hover:bg-indigo-50 transition-colors">
        + Add Section
      </button>
    </div>

    <div data-nested-form-target="container" class="space-y-2">
      <%= f.fields_for :sections do |sf| %>
        <%= render "custom_report_templates/section_row", sf: sf %>
      <% end %>
    </div>

    <template data-nested-form-target="template">
      <%= f.fields_for :sections, CustomReportTemplateSection.new, child_index: "__INDEX__" do |sf| %>
        <div class="flex items-center gap-2" data-nested-form-row>
          <%= sf.hidden_field :id %>
          <%= sf.hidden_field :_destroy, value: "0" %>
          <%= sf.text_field :name,
                placeholder: "Section name…",
                class: "flex-1 rounded-lg border border-gray-300 px-3 py-2 text-sm
                        focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
          <button type="button"
                  data-action="nested-form#remove"
                  class="p-1.5 rounded-lg text-gray-400 hover:text-red-500 hover:bg-red-50 transition-colors">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
      <% end %>
    </template>
  </div>

  <%# Buttons %>
  <div class="flex gap-3 pt-2">
    <%= f.submit template.new_record? ? "Create Template" : "Update Template",
          class: "inline-flex items-center px-5 py-2.5 bg-indigo-600 text-white text-sm font-semibold
                  rounded-lg hover:bg-indigo-700 transition-colors cursor-pointer" %>
    <%= link_to "Cancel", custom_report_templates_path,
          class: "inline-flex items-center px-4 py-2.5 bg-white text-gray-700 text-sm font-medium
                  rounded-lg border border-gray-200 hover:bg-gray-50 transition-colors" %>
  </div>
<% end %>
