<% content_for :title, "Report Templates" %>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Report Templates</h1>
    <p class="mt-1 text-sm text-gray-500">Custom templates for generating reports with selected fields</p>
  </div>
  <%= link_to "New Template", new_custom_report_template_path,
        class: "inline-flex items-center gap-1.5 px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition-colors" %>
</div>

<% if @templates.empty? %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 px-6 py-12 text-center">
    <p class="text-sm text-gray-400 italic">No report templates yet.</p>
    <%= link_to "Create your first template", new_custom_report_template_path,
          class: "mt-3 inline-block text-sm text-indigo-600 hover:text-indigo-800 font-medium" %>
  </div>
<% else %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <table class="min-w-full divide-y divide-gray-100 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Fields</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Sections</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Reports</th>
          <th class="px-4 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @templates.each do |tpl| %>
          <tr class="hover:bg-gray-50 transition-colors">
            <td class="px-4 py-3 font-medium text-gray-900"><%= tpl.name %></td>
            <td class="px-4 py-3 text-gray-500"><%= tpl.template_fields.size %> field<%= tpl.template_fields.size == 1 ? "" : "s" %></td>
            <td class="px-4 py-3 text-gray-500"><%= tpl.sections.size %> section<%= tpl.sections.size == 1 ? "" : "s" %></td>
            <td class="px-4 py-3 text-gray-500"><%= tpl.reports.size %></td>
            <td class="px-4 py-3 text-right">
              <div class="flex items-center justify-end gap-2">
                <%= link_to "Edit", edit_custom_report_template_path(tpl),
                      class: "text-xs text-indigo-600 hover:text-indigo-800 font-medium" %>
                <%= button_to "Delete", custom_report_template_path(tpl), method: :delete,
                      data: { action: "click->confirm#open",
                              confirm_message_param: "Delete template \"#{tpl.name}\"? #{tpl.reports.any? ? "#{tpl.reports.size} report(s) use this template." : "This cannot be undone."}" },
                      class: "text-xs text-red-600 hover:text-red-800 font-medium bg-transparent border-0 cursor-pointer" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
