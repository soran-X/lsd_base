<div id="<%= dom_id scout %>" class="divide-y divide-gray-100">
  <div class="px-6 py-4 flex items-start gap-4">
    <span class="text-xs font-medium text-gray-500 uppercase tracking-wider w-32 pt-0.5 shrink-0">Name</span>
    <span class="text-sm text-gray-900 font-medium"><%= scout.name %></span>
  </div>

  <div class="px-6 py-4 flex items-start gap-4">
    <span class="text-xs font-medium text-gray-500 uppercase tracking-wider w-32 pt-0.5 shrink-0">Specialty</span>
    <span class="text-sm text-gray-900">
      <%= scout.specialty.presence || content_tag(:span, "None", class: "text-gray-400 italic") %>
    </span>
  </div>

  <div class="px-6 py-4 flex items-start gap-4">
    <span class="text-xs font-medium text-gray-500 uppercase tracking-wider w-32 pt-0.5 shrink-0">Notes</span>
    <span class="text-sm text-gray-900 whitespace-pre-wrap">
      <%= scout.notes.presence || content_tag(:span, "None", class: "text-gray-400 italic") %>
    </span>
  </div>
</div>
