<%= form_with(model: scout, class: "contents") do |form| %>
  <% if scout.errors.any? %>
    <div class="mb-6 bg-red-50 border border-red-200 rounded-lg px-4 py-3">
      <h2 class="text-sm font-medium text-red-800 mb-2">
        <%= pluralize(scout.errors.count, "error") %> prevented this scout from being saved:
      </h2>
      <ul class="list-disc list-inside space-y-1">
        <% scout.errors.each do |error| %>
          <li class="text-sm text-red-700"><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="space-y-5">
    <div>
      <%= form.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_field :name,
            placeholder: "Enter scout name",
            class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
    </div>

    <div>
      <%= form.label :specialty, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_field :specialty,
            placeholder: "Enter specialty",
            class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
    </div>

    <div>
      <%= form.label :notes, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_area :notes,
            rows: 4,
            placeholder: "Enter any notes...",
            class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
    </div>
  </div>

  <div class="mt-6 flex items-center gap-3">
    <%= form.submit class: "inline-flex items-center px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition-colors cursor-pointer" %>
    <%= link_to "Cancel", scouts_path,
          class: "inline-flex items-center px-4 py-2 bg-white text-gray-700 text-sm font-medium rounded-lg border border-gray-200 hover:bg-gray-50 transition-colors" %>
  </div>
<% end %>
