<%= form_with model: company, class: "space-y-0" do |f| %>
  <% if company.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6 text-sm text-red-700">
      <ul class="list-disc list-inside space-y-0.5">
        <% company.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
      </ul>
    </div>
  <% end %>

  <%# ── Save (top) ──────────────────────────────────────────────────────── %>
  <div class="flex items-center gap-3 mb-6">
    <%= f.submit class: "inline-flex items-center px-5 py-2.5 bg-indigo-600 text-white text-sm
                          font-medium rounded-lg hover:bg-indigo-700 transition-colors cursor-pointer" %>
    <%= link_to "Cancel", company.persisted? ? company_path(company) : companies_path,
          class: "inline-flex items-center px-4 py-2 bg-white text-gray-700 text-sm
                  font-medium rounded-lg border border-gray-200 hover:bg-gray-50 transition-colors" %>
  </div>

  <%# ── Identity ────────────────────────────────────────────────────────── %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden mb-5">
    <div class="bg-gray-50 px-5 py-2.5 border-b border-gray-200">
      <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Identity</p>
    </div>
    <div class="p-5 space-y-4">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <%= f.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :name, placeholder: "Company name",
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                        focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
        </div>
        <div>
          <%= f.label :company_type_id, "Type", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.select :company_type_id,
                CompanyType.ordered.map { |ct| [ct.name, ct.id] },
                { include_blank: "— select type —", selected: company.company_type_id },
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                        focus:outline-none focus:ring-2 focus:ring-indigo-500 bg-white" %>
        </div>
      </div>
      <div>
        <%= f.label :website, "URL", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.url_field :website, placeholder: "https://",
              class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                      focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
      </div>
    </div>
  </div>

  <%# ── Address ─────────────────────────────────────────────────────────── %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden mb-5">
    <div class="bg-gray-50 px-5 py-2.5 border-b border-gray-200">
      <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Address</p>
    </div>
    <div class="p-5 space-y-4">
      <div>
        <%= f.label :address_line_1, "Address Line 1", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :address_line_1,
              class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                      focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
      </div>
      <div>
        <%= f.label :address_line_2, "Address Line 2", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :address_line_2,
              class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                      focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        <div class="col-span-2 sm:col-span-2">
          <%= f.label :city, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :city,
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                        focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
        </div>
        <div>
          <%= f.label :state, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :state,
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                        focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
        </div>
        <div>
          <%= f.label :postal_code, "Postal Code", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :postal_code,
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                        focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
        </div>
      </div>
      <div class="sm:w-1/2">
        <%= f.label :country, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :country,
              class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                      focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
      </div>
    </div>
  </div>

  <%# ── Contact Info ────────────────────────────────────────────────────── %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden mb-5">
    <div class="bg-gray-50 px-5 py-2.5 border-b border-gray-200">
      <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Contact Info</p>
    </div>
    <div class="p-5">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <%= f.label :phone, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.telephone_field :phone,
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                        focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
        </div>
        <div>
          <%= f.label :fax, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.telephone_field :fax,
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                        focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
        </div>
      </div>
    </div>
  </div>

  <%# ── Settings ────────────────────────────────────────────────────────── %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden mb-5">
    <div class="bg-gray-50 px-5 py-2.5 border-b border-gray-200">
      <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Settings</p>
    </div>
    <div class="p-5 flex flex-wrap gap-6">
      <label class="flex items-center gap-3 cursor-pointer select-none">
        <%= f.check_box :nest_subagents, class: "sr-only peer" %>
        <div class="relative w-11 h-6 rounded-full transition-colors bg-gray-200
                    peer-checked:bg-indigo-600
                    after:content-[''] after:absolute after:top-0.5 after:left-0.5
                    after:h-5 after:w-5 after:bg-white after:rounded-full after:shadow
                    after:transition-transform peer-checked:after:translate-x-5"></div>
        <span class="text-sm font-medium text-gray-700">Nest Subagents</span>
      </label>

      <label class="flex items-center gap-3 cursor-pointer select-none">
        <%= f.check_box :viewable_by_clients, class: "sr-only peer" %>
        <div class="relative w-11 h-6 rounded-full transition-colors bg-gray-200
                    peer-checked:bg-indigo-600
                    after:content-[''] after:absolute after:top-0.5 after:left-0.5
                    after:h-5 after:w-5 after:bg-white after:rounded-full after:shadow
                    after:transition-transform peer-checked:after:translate-x-5"></div>
        <span class="text-sm font-medium text-gray-700">Viewable by Clients</span>
      </label>
    </div>
  </div>

  <%# ── Notes ──────────────────────────────────────────────────────────── %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden mb-5">
    <div class="bg-gray-50 px-5 py-2.5 border-b border-gray-200">
      <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Notes</p>
    </div>
    <div class="p-5">
      <%= f.text_area :notes, rows: 5,
            placeholder: "Internal notes…",
            class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                    focus:outline-none focus:ring-2 focus:ring-indigo-500 resize-y" %>
    </div>
  </div>

  <%# ── Subagents ────────────────────────────────────────────────────────── %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden mb-5"
       data-controller="nested-form">
    <div class="bg-gray-50 px-5 py-2.5 border-b border-gray-200">
      <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Subagents</p>
    </div>

    <div class="divide-y divide-gray-100" data-nested-form-target="container">
      <%= f.fields_for :company_subagents do |sa| %>
        <div class="p-4 grid grid-cols-1 sm:grid-cols-3 gap-3 items-end" data-nested-form-row>
          <%= sa.hidden_field :id %>
          <%= sa.hidden_field :_destroy, value: "0" %>
          <div>
            <%= sa.label :territory_id, "Territory",
                  class: "block text-xs font-medium text-gray-600 mb-1" %>
            <%= sa.select :territory_id,
                  Territory.ordered.map { |t| [t.name, t.id] },
                  { include_blank: "— territory —", selected: sa.object.territory_id },
                  class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                          focus:outline-none focus:ring-2 focus:ring-indigo-500 bg-white" %>
          </div>
          <div class="relative"
               data-controller="company-combobox"
               data-company-combobox-url-value="<%= search_companies_path(format: :json) %>">
            <label class="block text-xs font-medium text-gray-600 mb-1">Company</label>
            <input type="text"
                   data-company-combobox-target="input"
                   value="<%= sa.object.subagent_company&.name %>"
                   placeholder="Search companies…"
                   autocomplete="off"
                   class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                           focus:outline-none focus:ring-2 focus:ring-indigo-500"
                   data-action="input->company-combobox#search keydown->company-combobox#onKeydown" />
            <input type="hidden"
                   name="<%= sa.object_name %>[subagent_company_id]"
                   value="<%= sa.object.subagent_company_id %>"
                   data-company-combobox-target="hiddenField" />
            <div data-company-combobox-target="dropdown"
                 class="hidden absolute z-20 left-0 right-0 mt-1 bg-white rounded-lg border
                        border-gray-200 shadow-lg overflow-hidden max-h-52 overflow-y-auto"></div>
          </div>
          <div class="flex items-end">
            <button type="button" data-action="nested-form#remove"
                    class="text-xs text-red-400 hover:text-red-600 pb-2.5 transition-colors">Remove</button>
          </div>
        </div>
      <% end %>
    </div>

    <template data-nested-form-target="template">
      <%= f.fields_for :company_subagents, CompanySubagent.new, child_index: "__INDEX__" do |sa| %>
        <div class="p-4 grid grid-cols-1 sm:grid-cols-3 gap-3 items-end" data-nested-form-row>
          <%= sa.hidden_field :id %>
          <%= sa.hidden_field :_destroy, value: "0" %>
          <div>
            <%= sa.label :territory_id, "Territory",
                  class: "block text-xs font-medium text-gray-600 mb-1" %>
            <%= sa.select :territory_id,
                  Territory.ordered.map { |t| [t.name, t.id] },
                  { include_blank: "— territory —" },
                  class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                          focus:outline-none focus:ring-2 focus:ring-indigo-500 bg-white" %>
          </div>
          <div class="relative"
               data-controller="company-combobox"
               data-company-combobox-url-value="<%= search_companies_path(format: :json) %>">
            <label class="block text-xs font-medium text-gray-600 mb-1">Company</label>
            <input type="text"
                   data-company-combobox-target="input"
                   placeholder="Search companies…"
                   autocomplete="off"
                   class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm
                           focus:outline-none focus:ring-2 focus:ring-indigo-500"
                   data-action="input->company-combobox#search keydown->company-combobox#onKeydown" />
            <input type="hidden"
                   name="<%= sa.object_name %>[subagent_company_id]"
                   value=""
                   data-company-combobox-target="hiddenField" />
            <div data-company-combobox-target="dropdown"
                 class="hidden absolute z-20 left-0 right-0 mt-1 bg-white rounded-lg border
                        border-gray-200 shadow-lg overflow-hidden max-h-52 overflow-y-auto"></div>
          </div>
          <div class="flex items-end">
            <button type="button" data-action="nested-form#remove"
                    class="text-xs text-red-400 hover:text-red-600 pb-2.5 transition-colors">Remove</button>
          </div>
        </div>
      <% end %>
    </template>

    <div class="px-5 py-3 bg-gray-50 border-t border-gray-100">
      <button type="button" data-action="nested-form#add"
              class="text-xs font-medium text-indigo-600 hover:text-indigo-800 transition-colors">
        + Add Subagent
      </button>
    </div>
  </div>

  <%# ── Save (bottom) ──────────────────────────────────────────────────── %>
  <div class="flex items-center gap-3">
    <%= f.submit class: "inline-flex items-center px-5 py-2.5 bg-indigo-600 text-white text-sm
                          font-medium rounded-lg hover:bg-indigo-700 transition-colors cursor-pointer" %>
    <%= link_to "Cancel", company.persisted? ? company_path(company) : companies_path,
          class: "inline-flex items-center px-4 py-2 bg-white text-gray-700 text-sm
                  font-medium rounded-lg border border-gray-200 hover:bg-gray-50 transition-colors" %>
  </div>
<% end %>
