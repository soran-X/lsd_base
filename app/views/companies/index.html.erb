<%# ── Header ──────────────────────────────────────────────────────────────── %>
<div class="flex items-center justify-between mb-4 gap-4 flex-wrap">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Companies</h1>
    <p class="text-sm text-gray-500 mt-0.5"><%= @companies.size %> <%= "company".pluralize(@companies.size) %></p>
  </div>
  <div class="flex items-center gap-3">
    <%= form_with url: companies_path, method: :get, class: "flex items-center gap-2" do |f| %>
      <%= hidden_field_tag :type, @type_filter if @type_filter.present? %>
      <%= f.text_field :q, value: @query, placeholder: "Search companies…",
            class: "block rounded-lg border border-gray-300 px-3 py-2 text-sm w-56
                    focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
      <% if @query.present? || @type_filter.present? %>
        <%= link_to "Clear", companies_path,
              class: "text-xs text-gray-400 hover:text-gray-600" %>
      <% end %>
    <% end %>
    <%= link_to "New Company", new_company_path,
          class: "inline-flex items-center gap-1.5 px-4 py-2 bg-indigo-600 text-white text-sm
                  font-medium rounded-lg hover:bg-indigo-700 transition-colors" %>
  </div>
</div>

<%# ── Type filter pills ───────────────────────────────────────────────────── %>
<div class="flex flex-wrap gap-2 mb-6">
  <%= link_to "All",
        companies_path(q: @query.presence),
        class: "px-3 py-1 rounded-full text-xs font-medium border transition-colors #{@type_filter.blank? ? 'bg-indigo-600 text-white border-indigo-600' : 'bg-white text-gray-600 border-gray-300 hover:border-indigo-400 hover:text-indigo-600'}" %>
  <% @company_types.each do |type| %>
    <%= link_to type,
          companies_path(type: type, q: @query.presence),
          class: "px-3 py-1 rounded-full text-xs font-medium border transition-colors #{@type_filter == type ? 'bg-indigo-600 text-white border-indigo-600' : 'bg-white text-gray-600 border-gray-300 hover:border-indigo-400 hover:text-indigo-600'}" %>
  <% end %>
</div>

<%# ── Table ───────────────────────────────────────────────────────────────── %>
<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
  <% if @companies.any? %>
    <table class="min-w-full divide-y divide-gray-100 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Name</th>
          <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider hidden sm:table-cell">Type</th>
          <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider hidden md:table-cell">City</th>
          <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider hidden lg:table-cell">Country</th>
          <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider hidden md:table-cell">Phone</th>
          <th class="px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider hidden sm:table-cell">Clients</th>
          <th class="px-5 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @companies.each do |company| %>
          <tr class="hover:bg-gray-50 group">
            <td class="px-5 py-3 font-medium text-gray-900">
              <%= link_to company.name, company_path(company),
                    class: "hover:text-indigo-600 transition-colors" %>
            </td>
            <td class="px-5 py-3 text-gray-500 hidden sm:table-cell">
              <%= company.company_type&.name || "—" %>
            </td>
            <td class="px-5 py-3 text-gray-500 hidden md:table-cell">
              <%= company.city.presence || "—" %>
            </td>
            <td class="px-5 py-3 text-gray-500 hidden lg:table-cell">
              <%= company.country.presence || "—" %>
            </td>
            <td class="px-5 py-3 text-gray-500 hidden md:table-cell">
              <%= company.phone.presence || "—" %>
            </td>
            <td class="px-5 py-3 text-center hidden sm:table-cell">
              <% if company.viewable_by_clients? %>
                <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">Yes</span>
              <% else %>
                <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-500">No</span>
              <% end %>
            </td>
            <td class="px-5 py-3 text-right">
              <div class="flex items-center justify-end gap-3 opacity-0 group-hover:opacity-100 transition-opacity">
                <%= link_to "Edit", edit_company_path(company),
                      class: "text-xs text-gray-500 hover:text-gray-700 font-medium" %>
                <%= button_to "Delete", company_path(company), method: :delete,
                      data: { action: "click->confirm#open",
                              confirm_message_param: "Remove \"#{company.name}\"?" },
                      class: "text-xs text-red-500 hover:text-red-700 font-medium bg-transparent border-0 cursor-pointer p-0" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="text-center py-16 text-sm text-gray-400">
      <% if @query.present? || @type_filter.present? %>
        <p>No companies match<%= " \"#{@query}\"" if @query.present? %><%= " in #{@type_filter}" if @type_filter.present? %>.</p>
        <%= link_to "Clear filters", companies_path, class: "text-indigo-600 hover:text-indigo-800 font-medium mt-2 inline-block" %>
      <% else %>
        <p class="mb-3">No companies yet.</p>
        <%= link_to "Add the first company", new_company_path,
              class: "text-indigo-600 hover:text-indigo-800 font-medium" %>
      <% end %>
    </div>
  <% end %>
</div>
