<% content_for :title, "Accept Invitation — #{app_name}" %>

<div class="min-h-screen flex items-center justify-center px-4" style="background-color: var(--color-secondary)">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <%= image_tag logo_url, alt: app_name, class: "h-12 object-contain mx-auto mb-6",
          onerror: "this.style.display='none';this.nextElementSibling.style.display='block'" %>
      <span class="text-2xl font-bold" style="display:none;color:var(--color-on-secondary)"><%= app_name %></span>
      <h1 class="text-2xl font-bold" style="color: var(--color-on-secondary)">Set your password</h1>
      <p class="mt-2 text-sm" style="color: var(--color-on-secondary-subtle)">
        Welcome, <%= @user.display_name %>. Choose a password to complete your account setup.
      </p>
    </div>

    <div class="bg-white rounded-2xl shadow-lg p-8">
      <% if @user.errors.any? %>
        <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6">
          <ul class="list-disc list-inside space-y-1">
            <% @user.errors.each do |error| %>
              <li class="text-sm text-red-700"><%= error.full_message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with scope: :user, url: invitation_path(params[:token]), method: :patch, class: "space-y-5" do |f| %>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
          <p class="block w-full rounded-lg border border-gray-200 bg-gray-50 px-3 py-2 text-sm text-gray-500"><%= @user.email %></p>
        </div>

        <div>
          <%= f.label :password, "Password", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.password_field :password, autocomplete: "new-password",
              class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent",
              placeholder: "Minimum 12 characters" %>
        </div>

        <div>
          <%= f.label :password_confirmation, "Confirm Password", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password",
              class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
        </div>

        <%= f.submit "Set Password & Sign In",
            class: "w-full inline-flex justify-center items-center px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition-colors cursor-pointer" %>
      <% end %>
    </div>
  </div>
</div>
