<%= turbo_stream_from "chat_bubble_user_#{Current.user.id}" %>

<div data-controller="chat-bubble"
     class="fixed bottom-6 right-6 z-50 flex flex-col items-end gap-2">
  <%# Chat window (hidden by default) %>
  <%# mark-read is here — static element, never replaced by turbo-frame, events bubble up from the input %>
  <div data-chat-bubble-target="window"
       data-controller="mark-read"
       data-mark-read-url-value="<%= mark_client_read_conversations_path %>"
       data-action="click->mark-read#run focusin->mark-read#run"
       class="hidden w-80 bg-white rounded-2xl shadow-2xl border border-gray-200 overflow-hidden flex flex-col"
       style="height: 480px;">
    <%# Window header %>
    <div class="px-4 py-3 flex items-center justify-between flex-shrink-0" style="background-color:var(--color-primary)">
      <div class="flex items-center gap-2">
        <div class="w-2 h-2 rounded-full bg-green-400"></div>
        <span class="text-white text-sm font-semibold">Support Chat</span>
      </div>
      <button data-action="click->chat-bubble#close"
              class="text-white/70 hover:text-white transition-colors text-xl leading-none">&times;</button>
    </div>

    <%# Turbo Frame loads the conversation lazily on first open %>
    <turbo-frame id="conversation"
                 data-chat-bubble-target="frame"
                 data-src="<%= mine_conversations_path %>"
                 class="flex-1 relative overflow-hidden min-h-0">
      <div class="flex-1 flex items-center justify-center">
        <p class="text-sm text-gray-400">Loading…</p>
      </div>
    </turbo-frame>
  </div>

  <%# Floating button %>
  <button data-action="click->chat-bubble#open"
          data-chat-bubble-target="button"
          class="relative w-14 h-14 rounded-full shadow-lg flex items-center justify-center text-white transition-transform hover:scale-105 active:scale-95"
          style="background-color:var(--color-primary)">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
    </svg>
    <%= render "layouts/chat_bubble_badge", count: client_unread_count %>
  </button>
</div>
