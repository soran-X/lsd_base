<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || app_name %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="<%= app_name %>">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="<%= favicon_url %>" type="image/svg+xml">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <% secondary = theme_color("secondary_color", "#111827") %>
    <% secondary_dark = color_is_dark?(secondary) %>
    <style>
      :root {
        --color-primary:            <%= theme_color("primary_color", "#4f46e5") %>;
        --color-secondary:          <%= secondary %>;
        --color-tertiary:           <%= theme_color("tertiary_color", "#6366f1") %>;
        --color-on-secondary:       <%= secondary_dark ? "#ffffff"           : "#111827" %>;
        --color-on-secondary-subtle:<%= secondary_dark ? "rgba(255,255,255,0.65)" : "rgba(17,24,39,0.55)" %>;
      }
      .bg-indigo-600                { background-color: var(--color-primary)   !important; }
      .hover\:bg-indigo-700:hover   { background-color: color-mix(in srgb, var(--color-primary) 85%, black) !important; }
      .focus\:ring-indigo-500:focus { --tw-ring-color:   var(--color-primary)   !important; }
      .text-indigo-600              { color:             var(--color-primary)   !important; }
      .hover\:text-indigo-800:hover { color:             color-mix(in srgb, var(--color-primary) 80%, black) !important; }
      .border-indigo-600            { border-color:      var(--color-primary)   !important; }
      .bg-indigo-500                { background-color:  var(--color-tertiary)  !important; }
    </style>
  </head>

  <body class="bg-gray-50 min-h-screen flex">
    <%# Sidebar %>
    <% if Current.user&.approved? %>
      <aside class="w-64 min-h-screen text-white flex flex-col fixed inset-y-0 left-0 z-10" style="background-color: var(--color-secondary)">
        <div class="px-4 py-5 border-b border-white/10 flex justify-center">
          <%= image_tag logo_url, alt: app_name, class: "w-full max-h-12 object-contain object-center",
              onerror: "this.style.display='none';this.nextElementSibling.style.display='flex'" %>
          <span class="text-xl font-bold tracking-tight text-white justify-center" style="display:none"><%= app_name %></span>
        </div>

        <nav class="flex-1 px-4 py-6 space-y-1 overflow-y-auto">
          <%= link_to dashboard_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors #{request.path == dashboard_path ? 'bg-indigo-600 text-white' : 'text-gray-300 hover:bg-gray-800 hover:text-white'}" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
            Dashboard
          <% end %>

          <div class="pt-4 pb-1">
            <p class="px-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Content</p>
          </div>

          <%= link_to books_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors #{request.path.start_with?(books_path) ? 'bg-indigo-600 text-white' : 'text-gray-300 hover:bg-gray-800 hover:text-white'}" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
            Books
          <% end %>

          <%= link_to authors_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors #{request.path.start_with?(authors_path) ? 'bg-indigo-600 text-white' : 'text-gray-300 hover:bg-gray-800 hover:text-white'}" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            Authors
          <% end %>

          <%= link_to scouts_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors #{request.path.start_with?(scouts_path) ? 'bg-indigo-600 text-white' : 'text-gray-300 hover:bg-gray-800 hover:text-white'}" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/></svg>
            Scouts
          <% end %>

          <% if Current.user.hierarchy_level >= 50 %>
            <%= turbo_stream_from "pending_users_badge" %>
            <%= turbo_stream_from "conversations_badge" %>
            <div class="pt-4 pb-1">
              <p class="px-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Admin</p>
            </div>

            <%= link_to users_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors #{request.path.start_with?(users_path) ? 'bg-indigo-600 text-white' : 'text-gray-300 hover:bg-gray-800 hover:text-white'}" do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              Users
              <%= render "layouts/pending_badge", count: pending_users_count %>
            <% end %>

            <%= link_to conversations_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors #{request.path.start_with?(conversations_path) ? 'bg-indigo-600 text-white' : 'text-gray-300 hover:bg-gray-800 hover:text-white'}" do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
              Conversations
              <%= render "layouts/conversations_badge", count: admin_unread_conversations_count %>
            <% end %>

            <%= link_to roles_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors #{request.path.start_with?(roles_path) ? 'bg-indigo-600 text-white' : 'text-gray-300 hover:bg-gray-800 hover:text-white'}" do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
              Roles
            <% end %>

            <%= link_to site_settings_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors #{request.path.start_with?(site_settings_path) ? 'bg-indigo-600 text-white' : 'text-gray-300 hover:bg-gray-800 hover:text-white'}" do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              Site Settings
            <% end %>
          <% end %>
        </nav>

          <div class="pt-4 pb-1">
            <p class="px-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Account</p>
          </div>

          <%= link_to new_two_factor_authentication_profile_totp_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors #{request.path.start_with?(two_factor_authentication_profile_recovery_codes_path) || request.path == new_two_factor_authentication_profile_totp_path ? 'bg-indigo-600 text-white' : 'text-gray-300 hover:bg-gray-800 hover:text-white'}" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
            </svg>
            Security / 2FA
            <% if Current.user.otp_required_for_sign_in? %>
              <span class="ml-auto text-xs bg-green-500 text-white px-1.5 py-0.5 rounded-full">On</span>
            <% end %>
          <% end %>

        <%# Sidebar footer — user info + sign out %>
        <div class="border-t border-white/10 px-4 py-4">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-indigo-500 flex items-center justify-center text-white text-sm font-semibold flex-shrink-0">
              <%= Current.user.initials %>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium text-white truncate"><%= Current.user.display_name %></p>
              <p class="text-xs text-gray-400 truncate"><%= Current.user.role&.name || "No role" %></p>
            </div>
          </div>
          <div class="mt-3">
            <%= button_to "Sign out", session_path(Current.session), method: :delete,
                class: "w-full text-left text-sm text-gray-400 hover:text-white transition-colors px-3 py-1 rounded hover:bg-gray-800" %>
          </div>
        </div>
      </aside>
    <% end %>

    <%# Main content %>
    <div class="<%= Current.user&.approved? ? 'ml-64' : '' %> flex-1 <%= content_for?(:wrapper_class) ? yield(:wrapper_class) : 'min-h-screen' %> flex flex-col">
      <%# Flash messages %>
      <% if notice.present? || alert.present? %>
        <div class="px-6 pt-4">
          <%= render "shared/flash" %>
        </div>
      <% end %>

      <main class="<%= content_for?(:main_class) ? yield(:main_class) : 'flex-1 px-6 py-8' %>">
        <%= yield %>
      </main>
    </div>

    <% if Current.user&.approved? && Current.user.hierarchy_level < 50 %>
      <%= render "layouts/chat_bubble" %>
    <% end %>

    <%# Toast notifications %>
    <% if Current.user&.approved? %>
      <% if Current.user.hierarchy_level >= 50 %>
        <%= turbo_stream_from "admin_toasts" %>
      <% else %>
        <%= turbo_stream_from "toast_user_#{Current.user.id}" %>
      <% end %>
      <div id="toast-container" style="position:fixed;top:1rem;right:1rem;z-index:50;display:flex;flex-direction:column;align-items:flex-end;gap:0.5rem;pointer-events:none"></div>
    <% end %>
  </body>
</html>
