<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || app_name %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="<%= app_name %>">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="<%= favicon_url %>" type="image/svg+xml">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "trix", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <% secondary      = theme_color("secondary_color", "#261c10") %>
    <% secondary_dark = color_is_dark?(secondary) %>
    <style>
      :root {
        --color-primary:             <%= theme_color("primary_color", "#3d6b52") %>;
        --color-secondary:           <%= secondary %>;
        --color-tertiary:            <%= theme_color("tertiary_color", "#b87333") %>;
        --color-on-secondary:        <%= secondary_dark ? "#ffffff"                : "#111827" %>;
        --color-on-secondary-subtle: <%= secondary_dark ? "rgba(255,255,255,0.65)": "rgba(17,24,39,0.55)" %>;
      }
      .bg-indigo-600                { background-color: var(--color-primary)   !important; }
      .hover\:bg-indigo-700:hover   { background-color: color-mix(in srgb, var(--color-primary) 85%, black) !important; }
      .focus\:ring-indigo-500:focus { --tw-ring-color:   var(--color-primary)   !important; }
      .text-indigo-600              { color:             var(--color-primary)   !important; }
      .hover\:text-indigo-800:hover { color:             color-mix(in srgb, var(--color-primary) 80%, black) !important; }
      .border-indigo-600            { border-color:      var(--color-primary)   !important; }
      .bg-indigo-500                { background-color:  var(--color-tertiary)  !important; }
    </style>
  </head>

  <body class="min-h-screen flex" style="background-color: #f7f3ee;"
        data-controller="sidebar confirm"
        data-sidebar-persist-value="lsd-sidebar-collapsed">

    <%# ── Sidebar ──────────────────────────────────────────────────────────── %>
    <% if Current.user&.approved? %>
      <aside data-sidebar-target="sidebar"
             class="sidebar-nav w-64 min-h-screen text-white flex flex-col fixed inset-y-0 left-0 z-40 overflow-hidden transition-transform duration-200"
             style="background-color: var(--color-secondary)">

        <%# Collapse toggle button %>
        <button type="button"
                data-action="click->sidebar#toggle"
                title="Toggle sidebar"
                class="absolute top-4 right-2 z-20 w-6 h-6 rounded-full bg-white/10 hover:bg-white/20
                       flex items-center justify-center transition-colors focus:outline-none">
          <svg data-sidebar-target="chevron"
               class="w-3.5 h-3.5 text-white/70 transition-transform duration-200"
               fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
          </svg>
        </button>

        <%# Logo %>
        <div class="px-4 py-5 border-b border-white/10 flex justify-center items-center min-h-[4.5rem]">
          <%= image_tag logo_url, alt: app_name,
                class: "max-h-10 object-contain sidebar-label",
                onerror: "this.style.display='none';this.nextElementSibling.style.display='flex'" %>
          <span class="text-xl font-bold tracking-tight text-white justify-center hidden sidebar-label"
                style="display:none"><%= app_name %></span>
          <%# Icon-only logo fallback when collapsed — just initials %>
          <span class="sidebar-collapsed-mark text-lg font-bold text-white hidden">
            <%= app_name.first(2).upcase %>
          </span>
        </div>

        <%# Navigation %>
        <nav class="flex-1 px-2 py-4 space-y-0.5 overflow-y-auto overflow-x-hidden">

          <%# Helper: active link classes %>
          <% def nav_link_class(active)
               base = "sidebar-link flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors w-full"
               active ? "#{base} bg-indigo-600 text-white" : "#{base} text-gray-300 hover:bg-white/10 hover:text-white"
             end %>

          <%= link_to dashboard_path,
                class: nav_link_class(request.path == dashboard_path),
                title: "Dashboard" do %>
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
            </svg>
            <span class="sidebar-label truncate">Dashboard</span>
          <% end %>

          <div class="pt-4 pb-1 sidebar-section">
            <p class="px-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Content</p>
          </div>
          <div class="pt-2 pb-1 sidebar-section-spacer hidden">&nbsp;</div>

          <%= link_to books_path,
                class: nav_link_class(request.path.start_with?(books_path)),
                title: "Books" do %>
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
            </svg>
            <span class="sidebar-label truncate">Books</span>
          <% end %>

          <%= link_to book_searches_path,
                class: nav_link_class(request.path.start_with?(book_searches_path)),
                title: "Advanced Search" do %>
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2a1 1 0 01-.293.707L13 13.414V19a1 1 0 01-.553.894l-4 2A1 1 0 017 21v-7.586L3.293 6.707A1 1 0 013 6V4z"/>
            </svg>
            <span class="sidebar-label truncate">Advanced Search</span>
          <% end %>

          <%= link_to authors_path,
                class: nav_link_class(request.path.start_with?(authors_path)),
                title: "Authors" do %>
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
            </svg>
            <span class="sidebar-label truncate">Authors</span>
          <% end %>

          <%= link_to companies_path,
                class: nav_link_class(request.path.start_with?(companies_path)),
                title: "Companies" do %>
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
            </svg>
            <span class="sidebar-label truncate">Companies</span>
          <% end %>

          <%= link_to contacts_path,
                class: nav_link_class(request.path.start_with?(contacts_path)),
                title: "Contacts" do %>
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
            </svg>
            <span class="sidebar-label truncate">Contacts</span>
          <% end %>

          <% if Current.user.hierarchy_level >= 50 %>
            <%= turbo_stream_from "pending_users_badge" %>
            <%= turbo_stream_from "conversations_badge" %>

            <div class="pt-4 pb-1 sidebar-section">
              <p class="px-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Admin</p>
            </div>

            <%= link_to users_path,
                  class: nav_link_class(request.path.start_with?(users_path)),
                  title: "Users" do %>
              <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <span class="sidebar-label truncate flex items-center gap-2">
                Users
                <%= render "layouts/pending_badge", count: pending_users_count %>
              </span>
            <% end %>

            <%= link_to conversations_path,
                  class: nav_link_class(request.path.start_with?(conversations_path)),
                  title: "Conversations" do %>
              <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
              </svg>
              <span class="sidebar-label truncate flex items-center gap-2">
                Conversations
                <%= render "layouts/conversations_badge", count: admin_unread_conversations_count %>
              </span>
            <% end %>

            <%= link_to roles_path,
                  class: nav_link_class(request.path.start_with?(roles_path)),
                  title: "Roles" do %>
              <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
              </svg>
              <span class="sidebar-label truncate">Roles</span>
            <% end %>

            <%= link_to company_types_path,
                  class: nav_link_class(request.path.start_with?(company_types_path)),
                  title: "Company Types" do %>
              <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z"/>
              </svg>
              <span class="sidebar-label truncate">Company Types</span>
            <% end %>

            <%= link_to territories_path,
                  class: nav_link_class(request.path.start_with?(territories_path)),
                  title: "Territories" do %>
              <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              <span class="sidebar-label truncate">Territories</span>
            <% end %>

            <%= link_to genres_path,
                  class: nav_link_class(request.path.start_with?(genres_path)),
                  title: "Genres" do %>
              <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z"/>
              </svg>
              <span class="sidebar-label truncate">Genres</span>
            <% end %>

            <%= link_to subgenres_path,
                  class: nav_link_class(request.path.start_with?(subgenres_path)),
                  title: "Subgenres" do %>
              <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
              </svg>
              <span class="sidebar-label truncate">Subgenres</span>
            <% end %>

            <%= link_to film_genres_path,
                  class: nav_link_class(request.path.start_with?(film_genres_path)),
                  title: "Film Genres" do %>
              <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M7 4v16M17 4v16M3 8h4m10 0h4M3 16h4m10 0h4M4 20h16a1 1 0 001-1V5a1 1 0 00-1-1H4a1 1 0 00-1 1v14a1 1 0 001 1z"/>
              </svg>
              <span class="sidebar-label truncate">Film Genres</span>
            <% end %>

            <%= link_to client_types_path,
                  class: nav_link_class(request.path.start_with?(client_types_path)),
                  title: "Client Types" do %>
              <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <span class="sidebar-label truncate">Client Types</span>
            <% end %>

            <%= link_to site_settings_path,
                  class: nav_link_class(request.path.start_with?(site_settings_path)),
                  title: "Site Settings" do %>
              <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <span class="sidebar-label truncate">Site Settings</span>
            <% end %>
          <% end %>

          <%# Account section %>
          <div class="pt-4 pb-1 sidebar-section">
            <p class="px-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Account</p>
          </div>

          <%= link_to new_two_factor_authentication_profile_totp_path,
                class: nav_link_class(
                  request.path.start_with?(two_factor_authentication_profile_recovery_codes_path) ||
                  request.path == new_two_factor_authentication_profile_totp_path
                ),
                title: "Security / 2FA" do %>
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
            </svg>
            <span class="sidebar-label truncate flex items-center gap-2">
              Security / 2FA
              <% if Current.user.otp_required_for_sign_in? %>
                <span class="text-xs bg-green-500 text-white px-1.5 py-0.5 rounded-full">On</span>
              <% end %>
            </span>
          <% end %>
        </nav>

        <%# Footer: avatar + name/role + sign-out %>
        <div class="border-t border-white/10 px-2 py-3">
          <div class="flex items-center gap-3 px-1">
            <div class="w-8 h-8 rounded-full bg-indigo-500 flex items-center justify-center
                        text-white text-sm font-semibold flex-shrink-0"
                 title="<%= Current.user.display_name %>">
              <%= Current.user.initials %>
            </div>
            <div class="flex-1 min-w-0 sidebar-footer">
              <p class="text-sm font-medium text-white truncate"><%= Current.user.display_name %></p>
              <p class="text-xs text-gray-400 truncate"><%= Current.user.role&.name || "No role" %></p>
            </div>
          </div>
          <div class="mt-2 sidebar-footer">
            <%= button_to "Sign out", session_path(Current.session), method: :delete,
                  class: "w-full text-left text-sm text-gray-400 hover:text-white transition-colors
                          px-3 py-1.5 rounded hover:bg-white/10" %>
          </div>
          <%# Icon-only sign out when collapsed %>
          <div class="mt-2 flex justify-center sidebar-collapsed-only hidden">
            <%= button_to session_path(Current.session), method: :delete,
                  class: "w-8 h-8 rounded-lg flex items-center justify-center text-gray-400
                          hover:text-white hover:bg-white/10 transition-colors",
                  title: "Sign out" do %>
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round"
                      d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
              </svg>
            <% end %>
          </div>
        </div>
      </aside>
    <% end %>

    <%# ── Mobile sidebar overlay backdrop ──────────────────────────────────── %>
    <% if Current.user&.approved? %>
      <div data-sidebar-target="overlay"
           data-action="click->sidebar#closeOverlay"
           class="hidden fixed inset-0 z-30 bg-black/50"></div>
    <% end %>

    <%# ── Mobile top bar ─────────────────────────────────────────────────────── %>
    <% if Current.user&.approved? %>
      <div class="md:hidden fixed top-0 left-0 right-0 z-20 h-14 flex items-center px-4"
           style="background-color: var(--color-secondary)">
        <button type="button"
                data-action="click->sidebar#toggle"
                class="p-2 -ml-2 rounded-lg text-white/70 hover:text-white hover:bg-white/10 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
        <span class="ml-3 text-white font-semibold text-sm"><%= app_name %></span>
      </div>
    <% end %>

    <%# ── Main content ──────────────────────────────────────────────────────── %>
    <div data-sidebar-target="main"
         class="<%= Current.user&.approved? ? 'ml-64' : '' %> flex-1 min-w-0 flex flex-col min-h-screen
                transition-[margin] duration-200 ease-in">
      <%# Spacer so content clears the fixed mobile top bar %>
      <% if Current.user&.approved? %>
        <div class="md:hidden h-14 shrink-0"></div>
      <% end %>

      <% if notice.present? || alert.present? %>
        <div class="px-6 pt-4">
          <%= render "shared/flash" %>
        </div>
      <% end %>

      <main class="<%= content_for?(:main_class) ? yield(:main_class) : 'flex-1 px-6 py-8' %>">
        <%= yield %>
      </main>
    </div>

    <% if Current.user&.approved? && Current.user.hierarchy_level < 50 %>
      <%= render "layouts/chat_bubble" %>
    <% end %>

    <% if Current.user&.approved? %>
      <% if Current.user.hierarchy_level >= 50 %>
        <%= turbo_stream_from "admin_toasts" %>
      <% else %>
        <%= turbo_stream_from "toast_user_#{Current.user.id}" %>
      <% end %>
      <div id="toast-container"
           style="position:fixed;top:1rem;right:1rem;z-index:50;display:flex;flex-direction:column;align-items:flex-end;gap:0.5rem;pointer-events:none"></div>
    <% end %>
    <%# ── Delete confirmation dialog ────────────────────────────────────────── %>
    <dialog data-confirm-target="dialog"
            class="confirm-dialog rounded-2xl shadow-2xl border-0 p-0 w-full max-w-sm">
      <div class="p-6">
        <div class="flex items-start gap-4 mb-5">
          <div class="shrink-0 w-10 h-10 rounded-full bg-red-100 flex items-center justify-center">
            <svg class="w-5 h-5 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
            </svg>
          </div>
          <div class="flex-1 min-w-0 pt-0.5">
            <h3 class="text-base font-semibold text-gray-900 mb-1">Confirm delete</h3>
            <p data-confirm-target="message" class="text-sm text-gray-500 leading-relaxed"></p>
          </div>
        </div>
        <div class="flex justify-end gap-2">
          <button data-action="click->confirm#cancel" type="button"
                  class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-200
                         rounded-lg hover:bg-gray-50 transition-colors">
            Cancel
          </button>
          <button data-action="click->confirm#submit" type="button"
                  class="px-4 py-2 text-sm font-medium text-white bg-red-600 hover:bg-red-700
                         rounded-lg transition-colors">
            Delete
          </button>
        </div>
      </div>
    </dialog>
  </body>
</html>
