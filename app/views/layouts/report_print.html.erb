<!DOCTYPE html>
<html>
  <head>
    <title><%= @report.title %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= stylesheet_link_tag "trix", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag :app,   "data-turbo-track": "reload" %>
    <style>
      body { font-family: Georgia, serif; font-size: 11pt; color: #111; margin: 0; padding: 0; }
      .print-wrapper { max-width: 760px; margin: 0 auto; padding: 2rem 2.5rem; }

      /* Report title block */
      .print-header { border-bottom: 2px solid #222; padding-bottom: 1rem; margin-bottom: 1.5rem; }
      .print-header h1 { font-size: 18pt; font-weight: bold; margin: 0 0 0.25rem; }
      .print-header .meta { font-size: 9pt; color: #555; }

      /* Body and footer rich text */
      .report-body,
      .report-footer { margin-bottom: 1.5rem; font-size: 10.5pt; line-height: 1.6; }
      .report-footer { margin-top: 2rem; border-top: 1px solid #ccc; padding-top: 1rem; color: #555; }

      /* Book entries */
      .report-book { margin-bottom: 1.5rem; page-break-inside: avoid; }
      .book-title-line { font-size: 11pt; margin: 0 0 0.35rem; }
      .report-field { font-size: 9.5pt; margin: 0.2rem 0; line-height: 1.5; }
      .report-label { font-weight: bold; }
      .report-rich-value { display: inline; }

      /* Film Memo */
      .report-section-heading {
        font-size: 13pt; font-weight: bold; text-transform: uppercase;
        letter-spacing: 0.05em; margin: 1.5rem 0 0.75rem;
        border-bottom: 1px solid #ccc; padding-bottom: 0.3rem;
      }

      /* Adult Highlights */
      .report-genre-heading {
        font-size: 11pt; font-weight: bold; font-style: italic;
        margin: 1.1rem 0 0.4rem; border-bottom: 1px solid #e5e5e5; padding-bottom: 0.15rem;
      }
      .book-subgenre  { font-style: italic; font-size: 9.5pt; margin: 0 0 0.1rem; }
      .book-authors   { font-weight: bold; font-style: normal; margin: 0 0 0.1rem; letter-spacing: 0.02em; }
      .book-title     { font-size: 11pt; margin: 0 0 0.2rem; }
      .book-tagline   { font-size: 9.5pt; color: #444; margin: 0 0 0.35rem; }

      /* Print toolbar */
      .print-toolbar {
        position: fixed; top: 0; left: 0; right: 0; z-index: 100;
        background: #1e293b; color: #fff; padding: 0.6rem 1.5rem;
        display: flex; align-items: center; gap: 0.75rem; font-family: system-ui, sans-serif;
        font-size: 13px;
      }
      .print-toolbar button {
        padding: 0.35rem 0.9rem; border-radius: 6px; border: none; cursor: pointer;
        font-size: 12px; font-weight: 600;
      }
      .btn-print  { background: #6366f1; color: #fff; }
      .btn-close  { background: rgba(255,255,255,0.15); color: #fff; }
      .print-toolbar span { color: rgba(255,255,255,0.5); font-size: 12px; }

      @media print {
        .print-toolbar { display: none !important; }
        body { padding-top: 0 !important; }
        .print-wrapper { padding: 1.5rem 2rem; }
      }

      body.toolbar-visible { padding-top: 44px; }
    </style>
  </head>
  <body class="toolbar-visible">
    <div class="print-toolbar">
      <button class="btn-print" onclick="window.print()">Print / Save as PDF</button>
      <button class="btn-close" onclick="window.close()">Close</button>
      <span><%= @report.type_label %> &bull; <%= @report.report_date&.strftime("%B %-d, %Y") || "No date" %></span>
    </div>

    <div class="print-wrapper">
      <% if SiteSetting.report_company_header? %>
        <% company_name    = SiteSetting.company_detail(:name) %>
        <% if company_name.present? %>
        <div style="text-align:center; margin-bottom:1.5rem; padding-bottom:1.25rem; border-bottom:1px solid #ccc;">
          <div style="font-size:16pt; font-weight:bold; font-family:Georgia,serif; margin-bottom:0.3rem;"><%= company_name %></div>
          <% detail_parts = [SiteSetting.company_detail(:address), SiteSetting.company_detail(:contact_person), SiteSetting.company_detail(:email), SiteSetting.company_detail(:phone)].compact_blank %>
          <% if detail_parts.any? %>
            <div style="font-size:9pt; font-style:italic; color:#555; font-family:Georgia,serif;"><%= detail_parts.join("  ·  ") %></div>
          <% end %>
        </div>
        <% end %>
      <% end %>
      <div class="print-header">
        <h1><%= @report.title %></h1>
        <div class="meta">
          <%= @report.type_label %>
          <% if @report.report_date %> &bull; <%= @report.report_date.strftime("%B %-d, %Y") %><% end %>
          <% if @report.sent? %> &bull; Sent<% end %>
        </div>
      </div>

      <div class="report-rendered-content">
        <%= @report.rendered_content.to_s.html_safe %>
      </div>
    </div>
  </body>
</html>
